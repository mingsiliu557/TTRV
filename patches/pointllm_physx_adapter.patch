+            f"{rec['response_accuracy']:.3f} | {rec['majority_ratio']:.3f} | "
+            f"{rec['geo_soft_gt_mass']:.3f} | {rec['geo_harmony_hm']:.3f} | {rec.get('object_id')} |"
+        )
