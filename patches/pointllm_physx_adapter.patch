+from typing import Any, Dict, Iterable, List, Optional, Sequence, Tuple
+
+os.environ.setdefault("HF_HUB_OFFLINE", "1")
+os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
+os.environ.setdefault("HF_DATASETS_OFFLINE", "1")
+
+import numpy as np
+import torch
+from tqdm import tqdm
+from transformers import AutoTokenizer, LogitsProcessor
+
+from pointllm.conversation import SeparatorStyle, conv_templates
+from pointllm.model import PointLLMLlamaForCausalLM
+from pointllm.utils import disable_torch_init
+
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+DEFAULT_DATASET = Path(
+    "/root/autodl-tmp/TTRV/physx_mcq_workspace/PhysX-3D/outputs/physxnet_mcq_verl.json"
+)
+DEFAULT_SIDECAR = Path(
+    "/root/autodl-tmp/TTRV/physx_mcq_workspace/PhysX-3D/outputs/physxnet_mcq.jsonl"
+)
+DEFAULT_PARTSEG_ROOT = Path(
+    "/root/autodl-tmp/TTRV/physx_mcq_workspace/PhysX-3D/"
+    "dataset_toolkits/physxnet/version_1/partseg"
+)
+MODEL_CANDIDATES = [
+    Path("/root/.cache/huggingface/hub/models--RunsenXu--PointLLM_7B_v1.2"),
+    Path("/root/autodl-tmp/.cache/huggingface/hub/models--RunsenXu--PointLLM_7B_v1.2"),
+    Path("/root/autodl-tmp/.cache/huggingface/transformers/models--RunsenXu--PointLLM_7B_v1.2"),
+]
+DEFAULT_MCQ_SYSTEM_PROMPT = (
+    "You are a multiple-choice question answering assistant. "
+    "Reply with the single option letter only: A, B, C, or D."
+)
+
+
+def setup_logging(log_path: Path) -> logging.Logger:
+    log_path.parent.mkdir(parents=True, exist_ok=True)
+    logger = logging.getLogger("physx_mcq_pointllm")
+    logger.setLevel(logging.INFO)
+    logger.handlers.clear()
+    formatter = logging.Formatter("%(asctime)s - %(levelname)s - %(message)s")
+    stream = logging.StreamHandler(sys.stdout)
+    stream.setFormatter(formatter)
+    file_handler = logging.FileHandler(log_path)
+    file_handler.setFormatter(formatter)
+    logger.addHandler(stream)
+    logger.addHandler(file_handler)
+    return logger
+
+
+def resolve_model_path(path_arg: Optional[str]) -> Path:
+    candidates = [Path(path_arg).expanduser()] if path_arg else MODEL_CANDIDATES
+    for candidate in candidates:
+        if (candidate / "config.json").exists():
+            return candidate
+        snapshots = candidate / "snapshots"
+        if not snapshots.exists():
+            continue
+        refs_main = candidate / "refs" / "main"
+        snapshot_names: List[str] = []
+        if refs_main.exists():
+            snapshot_names.append(refs_main.read_text().strip())
+        snapshot_names.extend(sorted(p.name for p in snapshots.iterdir() if p.is_dir()))
+        seen = set()
+        for name in snapshot_names:
+            if not name or name in seen:
+                continue
+            seen.add(name)
+            snapshot = snapshots / name
+            if (snapshot / "config.json").exists() and (
+                (snapshot / "pytorch_model.bin.index.json").exists()
+                or any(snapshot.glob("pytorch_model-*.bin"))
+            ):
+                return snapshot
+    searched = ", ".join(str(p) for p in candidates)
+    raise FileNotFoundError(f"No complete local PointLLM snapshot found under: {searched}")
+
+
+def read_dataset(path: Path) -> List[Dict[str, Any]]:
+    with path.open("r", encoding="utf-8") as f:
+        data = json.load(f)
+    if not isinstance(data, list):
+        raise ValueError(f"Expected list dataset in {path}, got {type(data).__name__}")
+    return data
+
+
+def read_sidecar(path: Path) -> Dict[str, Dict[str, Any]]:
+    if not path.exists():
+        return {}
+    rows: Dict[str, Dict[str, Any]] = {}
+    with path.open("r", encoding="utf-8") as f:
+        for line in f:
+            if not line.strip():
+                continue
+            row = json.loads(line)
+            if row.get("id"):
+                rows[row["id"]] = row
+    return rows
+
+
+def object_id_from_example(example: Dict[str, Any], sidecar: Optional[Dict[str, Any]]) -> Optional[str]:
+    if sidecar and sidecar.get("object_id") is not None:
+        return str(sidecar["object_id"])
+    image_path = example.get("image_path") or ""
+    marker = "/partseg/"
+    if marker in image_path:
+        return image_path.split(marker, 1)[1].split("/", 1)[0]
+    return None
+
+
+def target_part_label_from_example(
+    example: Dict[str, Any], sidecar: Optional[Dict[str, Any]]
+) -> Optional[str]:
+    if sidecar:
+        source = sidecar.get("source") or {}
+        part_label = source.get("part_label")
+        if part_label is not None:
+            return str(part_label)
+    image_name = Path(example.get("image_path") or "").name
+    match = re.match(r"^(\d+)(?:_|\.|$)", image_name)
+    return match.group(1) if match else None
+
+
+def parse_obj(path: Path) -> Tuple[np.ndarray, np.ndarray]:
+    vertices: List[Tuple[float, float, float]] = []
+    faces: List[Tuple[int, int, int]] = []
+    with path.open("r", encoding="utf-8", errors="ignore") as f:
+        for line in f:
+            if line.startswith("v "):
+                parts = line.split()
+                if len(parts) >= 4:
+                    vertices.append((float(parts[1]), float(parts[2]), float(parts[3])))
+            elif line.startswith("f "):
+                raw_indices = []
+                for token in line.split()[1:]:
+                    idx_text = token.split("/", 1)[0]
+                    if not idx_text:
+                        continue
+                    idx = int(idx_text)
+                    if idx < 0:
+                        idx = len(vertices) + idx
+                    else:
+                        idx = idx - 1
+                    raw_indices.append(idx)
+                if len(raw_indices) >= 3:
+                    root = raw_indices[0]
+                    for i in range(1, len(raw_indices) - 1):
+                        faces.append((root, raw_indices[i], raw_indices[i + 1]))
+    return np.asarray(vertices, dtype=np.float32), np.asarray(faces, dtype=np.int64)
+
+
+def load_meshes(paths: Sequence[Path]) -> Tuple[np.ndarray, np.ndarray]:
+    all_vertices: List[np.ndarray] = []
+    all_faces: List[np.ndarray] = []
+    offset = 0
+    for path in paths:
+        vertices, faces = parse_obj(path)
+        if vertices.size == 0:
+            continue
+        all_vertices.append(vertices)
+        if faces.size:
+            all_faces.append(faces + offset)
+        offset += len(vertices)
+    if not all_vertices:
+        raise ValueError("no vertices found in OBJ files")
+    vertices = np.concatenate(all_vertices, axis=0)
+    faces = np.concatenate(all_faces, axis=0) if all_faces else np.empty((0, 3), dtype=np.int64)
+    return vertices, faces
+
+
+def stable_seed(seed: int, key: str) -> int:
+    digest = hashlib.sha256(f"{seed}:{key}".encode("utf-8")).digest()
+    return int.from_bytes(digest[:8], "little") % (2**32)
+
+
+def sample_points(vertices: np.ndarray, faces: np.ndarray, pointnum: int, rng: np.random.Generator) -> np.ndarray:
+    if len(vertices) == 0:
+        raise ValueError("cannot sample from empty vertex array")
+    if len(faces) == 0:
+        replace = len(vertices) < pointnum
+        idx = rng.choice(len(vertices), size=pointnum, replace=replace)
+        return vertices[idx].astype(np.float32)
+
+    tris = vertices[faces]
+    cross = np.cross(tris[:, 1] - tris[:, 0], tris[:, 2] - tris[:, 0])
+    areas = np.linalg.norm(cross, axis=1) * 0.5
+    valid = areas > 1e-12
+    if not np.any(valid):
+        replace = len(vertices) < pointnum
+        idx = rng.choice(len(vertices), size=pointnum, replace=replace)
+        return vertices[idx].astype(np.float32)
+
+    tris = tris[valid]
+    areas = areas[valid]
+    probs = areas / areas.sum()
+    tri_idx = rng.choice(len(tris), size=pointnum, replace=True, p=probs)
+    chosen = tris[tri_idx]
+    u = rng.random(pointnum, dtype=np.float32)
+    v = rng.random(pointnum, dtype=np.float32)
+    flip = u + v > 1.0
+    u[flip] = 1.0 - u[flip]
+    v[flip] = 1.0 - v[flip]
+    points = chosen[:, 0] + u[:, None] * (chosen[:, 1] - chosen[:, 0]) + v[:, None] * (
+        chosen[:, 2] - chosen[:, 0]
+    )
+    return points.astype(np.float32)
+
+
+def normalize_xyz(points: np.ndarray) -> np.ndarray:
+    centroid = points.mean(axis=0, keepdims=True)
+    points = points - centroid
+    radius = np.sqrt((points**2).sum(axis=1)).max()
+    if radius > 0:
+        points = points / radius
+    return points.astype(np.float32)
+
+
+def obj_paths_for_example(
+    partseg_root: Path,
+    object_id: str,
+    point_scope: str,
+    target_part_label: Optional[str],
+) -> List[Path]:
+    obj_dir = partseg_root / object_id / "objs"
+    if point_scope == "target_part":
+        if target_part_label is None:
+            raise FileNotFoundError("target part label unavailable")
+        path = obj_dir / f"{target_part_label}.obj"
+        if not path.exists():
+            raise FileNotFoundError(f"target part OBJ missing: {path}")
+        return [path]
+    paths = sorted(obj_dir.glob("*.obj"), key=lambda p: (len(p.stem), p.stem))
+    if not paths:
+        raise FileNotFoundError(f"no OBJ files found under {obj_dir}")
+    return paths
+
+
+def get_or_create_point_cloud(
+    example: Dict[str, Any],
+    sidecar: Optional[Dict[str, Any]],
+    partseg_root: Path,
+    cache_dir: Path,
+    point_scope: str,
+    pointnum: int,
+    seed: int,
+) -> Tuple[Path, np.ndarray, str]:
+    object_id = object_id_from_example(example, sidecar)
+    if object_id is None:
+        raise ValueError("object_id unavailable")
+    part_label = target_part_label_from_example(example, sidecar)
+    cache_key = f"{object_id}_{point_scope}"
+    if point_scope == "target_part":
+        cache_key += f"_{part_label or 'unknown'}"
+    cache_name = f"{cache_key}_{pointnum}_seed{seed}.npy"
+    cache_path = cache_dir / cache_name
+    if cache_path.exists():
+        return cache_path, np.load(cache_path), object_id
+
+    paths = obj_paths_for_example(partseg_root, object_id, point_scope, part_label)
+    vertices, faces = load_meshes(paths)
+    rng = np.random.default_rng(stable_seed(seed, cache_key))
+    xyz = normalize_xyz(sample_points(vertices, faces, pointnum, rng))
+    rgb = np.zeros_like(xyz, dtype=np.float32)
+    point_cloud = np.concatenate([xyz, rgb], axis=1).astype(np.float32)
+    cache_dir.mkdir(parents=True, exist_ok=True)
+    np.save(cache_path, point_cloud)
+    return cache_path, point_cloud, object_id
+
+
+def adapt_mcq_prompt(raw_prompt: str, prompt_suffix: str = "") -> str:
+    """Keep the dataset prompt; optionally add a short answer cue for ablations."""
+    prompt = raw_prompt.strip()
+    suffix = prompt_suffix.strip()
+    if suffix and not prompt.rstrip().endswith(suffix):
+        prompt = f"{prompt}\n{suffix}"
+    return prompt
+
+
+def build_point_prompt(raw_prompt: str, point_backbone_config: Dict[str, Any], prompt_suffix: str = "") -> str:
+    point_token_len = point_backbone_config["point_token_len"]
+    patch = point_backbone_config["default_point_patch_token"] * point_token_len
+    if point_backbone_config["mm_use_point_start_end"]:
+        point_tokens = (
+            point_backbone_config["default_point_start_token"]
+            + patch
+            + point_backbone_config["default_point_end_token"]
+        )
+    else:
+        point_tokens = patch
+    raw_prompt = adapt_mcq_prompt(raw_prompt, prompt_suffix=prompt_suffix)
+    if "<image>" in raw_prompt:
+        return raw_prompt.replace("<image>", point_tokens, 1)
+    return point_tokens + "\n" + raw_prompt
+
+
+def build_input_ids(
+    raw_prompt: str,
+    model: PointLLMLlamaForCausalLM,
+    tokenizer: AutoTokenizer,
+    conv_mode: str,
+    prompt_suffix: str,
+    system_prompt: str,
+) -> torch.Tensor:
+    conv = conv_templates[conv_mode].copy()
+    if system_prompt:
+        conv.system = system_prompt
+    qs = build_point_prompt(raw_prompt, model.get_model().point_backbone_config, prompt_suffix=prompt_suffix)
+    conv.append_message(conv.roles[0], qs)
+    conv.append_message(conv.roles[1], None)
+    prompt = conv.get_prompt()
+    inputs = tokenizer([prompt])
+    return torch.as_tensor(inputs.input_ids, device="cuda")
+
+
+def clean_generation(output: str, conv_mode: str) -> str:
+    conv = conv_templates[conv_mode].copy()
+    stop_str = conv.sep if conv.sep_style != SeparatorStyle.TWO else conv.sep2
+    output = output.strip()
+    if stop_str and stop_str in output:
+        output = output.split(stop_str, 1)[0].strip()
+    return output
+
+
+OPTION_TEXT_SKIP = {"a", "an", "the", "and", "or", "of", "with", "other", "object", "part"}
+
+
+def _normalize_option_text(text: str) -> str:
+    return re.sub(r"[^a-z0-9]+", " ", text.lower()).strip()
+
+
+def _option_tokens(text: str) -> List[str]:
+    return [token for token in _normalize_option_text(text).split() if token not in OPTION_TEXT_SKIP]
+
+
+def _option_phrase_variants(text: str) -> List[str]:
+    variants = [_normalize_option_text(text)]
+    without_parenthetical = re.sub(r"\([^)]*\)", " ", str(text))
+    variants.append(_normalize_option_text(without_parenthetical))
+    seen = set()
+    out = []
+    for variant in variants:
+        if len(variant) < 3 or variant in OPTION_TEXT_SKIP or variant in seen:
+            continue
+        seen.add(variant)
+        out.append(variant)
+    return out
+
+
+def _extract_prompt_options(prompt: Optional[str]) -> Dict[str, str]:
+    if not prompt:
+        return {}
+    matches = re.findall(
+        r"(?:^|\n)\s*([ABCD])\.\s*(.*?)(?=(?:\n\s*[ABCD]\.)|\s+ASSISTANT:|$)",
+        prompt,
+        flags=re.S,
+    )
+    return {choice.upper(): text.strip() for choice, text in matches}
+
+
+def _match_option_text(raw: str, prompt: Optional[str]) -> Optional[str]:
+    options = _extract_prompt_options(prompt)
+    if not options:
+        return None
+    raw_norm = _normalize_option_text(raw)
+    matches: List[Tuple[int, str]] = []
+    for choice, option_text in options.items():
+        for option_norm in _option_phrase_variants(option_text):
+            if option_norm in raw_norm:
+                matches.append((len(option_norm), choice))
+    if not matches:
+        raw_tokens = set(_option_tokens(raw))
+        token_matches: List[Tuple[int, float, int, str]] = []
+        for choice, option_text in options.items():
+            option_tokens = _option_tokens(option_text)
+            if not option_tokens:
+                continue
+            option_set = set(option_tokens)
+            overlap = sum(1 for token in option_set if token in raw_tokens)
+            if not overlap:
+                continue
+            ratio = overlap / len(option_set)
+            if overlap == len(option_set) or overlap >= 2:
+                token_matches.append((overlap, ratio, len(option_set), choice))
+        if not token_matches:
+            return None
+        best = max(token_matches, key=lambda item: (item[0], item[1], item[2]))
+        best_choices = [
+            choice
+            for overlap, ratio, token_count, choice in token_matches
+            if (overlap, ratio, token_count) == best[:3]
+        ]
+        return best_choices[0] if len(best_choices) == 1 else None
+    max_len = max(length for length, _choice in matches)
+    choices = {choice for length, choice in matches if length == max_len}
+    return next(iter(choices)) if len(choices) == 1 else None
+
+
+def parse_prediction(raw: str, prompt: Optional[str] = None) -> str:
+    text = raw.strip().replace("</s>", " ").replace("<|im_end|>", " ")
+    first = re.match(r"^\s*[\(\[]?\s*([ABCD])\s*[\)\]]?\s*$", text, flags=re.I)
+    if first:
+        return first.group(1).upper()
+    first = re.match(r"^\s*[\(\[]?\s*([ABCD])\s*[\)\].,:;-]", text, flags=re.I)
+    if first:
+        return first.group(1).upper()
+    guided = re.search(
+        r"(?:answer|option|choice|letter|choose|select|pick)\s*(?:is|:|-)?\s*[\(\[]?\s*['\"]?([ABCD])\b",
+        text,
+        flags=re.I,
+    )
+    if guided:
+        return guided.group(1).upper()
+    standalone = re.findall(r"\b([ABCD])\b", text)
+    if standalone:
+        # Only accept uppercase standalone letters here. A case-insensitive
+        # fallback incorrectly maps the English article "a" to option A.
+        return standalone[-1].upper()
+    option_match = _match_option_text(text, prompt)
+    if option_match:
+        return option_match
+    return "unknown"
+
+
+def get_choice_token_ids(tokenizer: AutoTokenizer) -> Dict[str, int]:
+    token_ids: Dict[str, int] = {}
+    for choice in ("A", "B", "C", "D"):
+        ids = tokenizer.encode(choice, add_special_tokens=False)
+        if len(ids) != 1:
+            raise ValueError(f"Choice {choice!r} is not a single tokenizer token: {ids}")
+        token_ids[choice] = ids[0]
+    return token_ids
+
+
+class ChoiceOnlyLogitsProcessor(LogitsProcessor):
+    def __init__(self, allowed_token_ids: Sequence[int]):
+        self.allowed_token_ids = list(allowed_token_ids)
+
+    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor) -> torch.FloatTensor:
+        masked = torch.full_like(scores, -float("inf"))
+        allowed = torch.tensor(self.allowed_token_ids, device=scores.device, dtype=torch.long)
+        masked.index_copy_(dim=-1, index=allowed, source=scores.index_select(dim=-1, index=allowed))
+        return masked
+
+
+def init_model(model_path: Path, torch_dtype: torch.dtype) -> Tuple[PointLLMLlamaForCausalLM, AutoTokenizer]:
+    disable_torch_init()
+    tokenizer = AutoTokenizer.from_pretrained(str(model_path), local_files_only=True)
+    model = PointLLMLlamaForCausalLM.from_pretrained(
+        str(model_path),
+        low_cpu_mem_usage=False,
+        use_cache=True,
+        torch_dtype=torch_dtype,
+        local_files_only=True,
+    ).cuda()
+    model.initialize_tokenizer_point_backbone_config_wo_embedding(tokenizer)
+    model.eval()
+    return model, tokenizer
+
+
+def predict_choice_from_logits(
+    model: PointLLMLlamaForCausalLM,
+    tokenizer: AutoTokenizer,
+    input_ids: torch.Tensor,
+    point_cloud: np.ndarray,
+) -> Tuple[str, Dict[str, float]]:
+    """Choose directly among A/B/C/D for the next token.
+
+    Optional stricter mode: use the model's next-token distribution and select
+    among the four answer letters.
+    """
+    choice_token_ids = get_choice_token_ids(tokenizer)
+    point_tensor = torch.from_numpy(point_cloud).unsqueeze(0).to(device="cuda", dtype=model.dtype)
+    with torch.inference_mode():
+        outputs = model(
+            input_ids=input_ids,
+            point_clouds=point_tensor,
+            use_cache=False,
+            return_dict=True,
+        )
+        logits = outputs.logits[0, -1]
+        ids = torch.tensor([choice_token_ids[c] for c in ("A", "B", "C", "D")], device=logits.device)
+        choice_logits = logits.index_select(0, ids).float()
+        probs = torch.softmax(choice_logits, dim=0)
+        best_idx = int(torch.argmax(choice_logits).item())
+    choices = ("A", "B", "C", "D")
+    scores = {
+        choice: float(probs[i].detach().cpu().item())
+        for i, choice in enumerate(choices)
+    }
+    return choices[best_idx], scores
+
+
+def generate_one_constrained_choice(
+    model: PointLLMLlamaForCausalLM,
+    tokenizer: AutoTokenizer,
+    input_ids: torch.Tensor,
+    point_cloud: np.ndarray,
+) -> str:
+    choice_token_ids = get_choice_token_ids(tokenizer)
+    allowed_ids = [choice_token_ids[c] for c in ("A", "B", "C", "D")]
+    point_tensor = torch.from_numpy(point_cloud).unsqueeze(0).to(device="cuda", dtype=model.dtype)
+    with torch.inference_mode():
+        output_ids = model.generate(
+            input_ids,
+            point_clouds=point_tensor,
+            do_sample=False,
+            max_new_tokens=1,
+            logits_processor=[ChoiceOnlyLogitsProcessor(allowed_ids)],
+            use_cache=True,
+            pad_token_id=tokenizer.pad_token_id,
+            eos_token_id=tokenizer.eos_token_id,
+        )
+    input_token_len = input_ids.shape[1]
+    output = tokenizer.batch_decode(output_ids[:, input_token_len:], skip_special_tokens=True)[0]
+    return output.strip()
+
+
+def generate_one(
+    model: PointLLMLlamaForCausalLM,
+    tokenizer: AutoTokenizer,
+    input_ids: torch.Tensor,
+    point_cloud: np.ndarray,
+    max_new_tokens: int,
+    conv_mode: str,
+) -> str:
+    point_tensor = torch.from_numpy(point_cloud).unsqueeze(0).to(device="cuda", dtype=model.dtype)
+    with torch.inference_mode():
+        output_ids = model.generate(
+            input_ids,
+            point_clouds=point_tensor,
+            do_sample=False,
+            max_new_tokens=max_new_tokens,
+            use_cache=True,
+            pad_token_id=tokenizer.pad_token_id,
+            eos_token_id=tokenizer.eos_token_id,
+        )
+    input_token_len = input_ids.shape[1]
+    output = tokenizer.batch_decode(output_ids[:, input_token_len:], skip_special_tokens=True)[0]
+    return clean_generation(output, conv_mode)
+
+
+def pct(num: int, den: int) -> float:
+    return float(num) / float(den) if den else 0.0
+
+
+def update_type_stats(stats: Dict[str, Dict[str, int]], question_type: str, correct: bool, invalid: bool) -> None:
+    row = stats.setdefault(question_type, {"num_evaluated": 0, "num_correct": 0, "invalid_outputs": 0})
+    row["num_evaluated"] += 1
+    row["num_correct"] += int(correct)
+    row["invalid_outputs"] += int(invalid)
+
+
+def write_json(path: Path, payload: Dict[str, Any]) -> None:
+    with path.open("w", encoding="utf-8") as f:
+        json.dump(payload, f, ensure_ascii=False, indent=2)
+
+
+def render_report(metrics: Dict[str, Any]) -> str:
+    lines = [
+        "# PhysX MCQ PointLLM 7B Preliminary Evaluation",
+        "",
+        f"- Model path: `{metrics['model_path']}`",
+        f"- Dataset path: `{metrics['dataset_path']}`",
+        f"- Sidecar path: `{metrics.get('sidecar_path')}`",
+        f"- Command used: `{metrics['command']}`",
+        f"- Point preprocessing: {metrics['point_preprocessing']}",
+        f"- Total dataset examples: {metrics['num_total']}",
+        f"- Evaluated examples: {metrics['num_evaluated']}",
+        f"- Correct: {metrics['num_correct']}",
+        f"- Accuracy: {metrics['accuracy']:.6f}",
+        f"- Invalid outputs: {metrics['invalid_outputs']}",
+        f"- Skipped: `{json.dumps(metrics['skipped'], ensure_ascii=False)}`",
+        f"- Runtime seconds: {metrics['runtime_seconds']:.2f}",
+        "",
+        "## Accuracy By Question Type",
+        "",
+        "| question_type | evaluated | correct | accuracy | invalid_outputs |",
+        "| --- | ---: | ---: | ---: | ---: |",
+    ]
+    for question_type, row in sorted(metrics["accuracy_by_question_type"].items()):
+        lines.append(
+            f"| {question_type} | {row['num_evaluated']} | {row['num_correct']} | "
+            f"{row['accuracy']:.6f} | {row['invalid_outputs']} |"
+        )
+    lines.extend(
+        [
+            "",
+            "## Runtime Notes And Known Limitations",
+            "",
+        ]
+    )
+    for note in metrics["runtime_notes_and_known_limitations"]:
+        lines.append(f"- {note}")
+    lines.append("")
+    return "\n".join(lines)
+
+
+def ensure_can_write(paths: Iterable[Path], overwrite: bool) -> None:
+    existing = [str(path) for path in paths if path.exists()]
+    if existing and not overwrite:
+        joined = "\n".join(existing)
+        raise FileExistsError(f"Output files already exist. Use --overwrite to replace:\n{joined}")
+
+
+def dtype_from_name(name: str) -> torch.dtype:
+    return {"float32": torch.float32, "float16": torch.float16, "bfloat16": torch.bfloat16}[name]
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--dataset_path", type=Path, default=DEFAULT_DATASET)
+    parser.add_argument("--sidecar_path", type=Path, default=DEFAULT_SIDECAR)
+    parser.add_argument("--partseg_root", type=Path, default=DEFAULT_PARTSEG_ROOT)
+    parser.add_argument("--model_path", type=str, default=None)
+    parser.add_argument("--max_examples", type=int, default=200)
+    parser.add_argument("--start_index", type=int, default=0)
+    parser.add_argument("--pointnum", type=int, default=8192)
+    parser.add_argument("--seed", type=int, default=0)
+    parser.add_argument("--point_scope", choices=["full_object", "target_part"], default="full_object")
+    parser.add_argument(
+        "--answer_mode",
+        choices=["constrained_generate", "choice_logits", "freeform"],
+        default="freeform",
+        help=(
+            "constrained_generate masks generation to A/B/C/D for one token; "
+            "choice_logits selects among A/B/C/D next-token logits; "
+            "freeform runs open-ended generation then parses it like VERL/TTRL."
+        ),
+    )
+    parser.add_argument(
+        "--prompt_suffix",
+        type=str,
+        default="",
+        help=(
+            "Optional suffix appended to the user MCQ prompt before the assistant turn. "
+            "Default is empty to match the VERL-style prompt that ends after option D."
+        ),
+    )
+    parser.add_argument(
+        "--system_prompt",
+        type=str,
+        default=DEFAULT_MCQ_SYSTEM_PROMPT,
+        help="Conversation system prompt adapter. Use '' to keep the original PointLLM/Vicuna system prompt.",
+    )
+    parser.add_argument("--max_new_tokens", type=int, default=8)
+    parser.add_argument("--torch_dtype", choices=["float32", "float16", "bfloat16"], default="bfloat16")
+    parser.add_argument("--conv_mode", default="vicuna_v1_1")
+    parser.add_argument("--output_prefix", type=Path, default=REPO_ROOT / "outputs" / "physx_mcq_pointllm7b")
+    parser.add_argument("--log_path", type=Path, default=REPO_ROOT / "logs" / "physx_mcq_pointllm7b_eval.log")
+    parser.add_argument("--cache_dir", type=Path, default=REPO_ROOT / "outputs" / "physxnet_point_cache")
+    parser.add_argument("--overwrite", action="store_true")
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    predictions_path = args.output_prefix.with_name(args.output_prefix.name + "_predictions.jsonl")
+    metrics_path = args.output_prefix.with_name(args.output_prefix.name + "_metrics.json")
+    report_path = args.output_prefix.with_name(args.output_prefix.name + "_report.md")
+    ensure_can_write([predictions_path, metrics_path, report_path, args.log_path], args.overwrite)
+
+    logger = setup_logging(args.log_path)
+    start_time = time.time()
+    command = " ".join(shlex.quote(x) for x in [sys.executable, *sys.argv])
+    model_path = resolve_model_path(args.model_path)
+    logger.info("Command: %s", command)
+    logger.info("Using model path: %s", model_path)
+    logger.info("Using dataset path: %s", args.dataset_path)
+    logger.info("Using sidecar path: %s", args.sidecar_path)
+    logger.info("Using point cache: %s", args.cache_dir)
+    logger.info("Point scope: %s", args.point_scope)
+
+    data = read_dataset(args.dataset_path)
+    sidecar = read_sidecar(args.sidecar_path)
+    num_total = len(data)
+    stop_index = num_total if args.max_examples < 0 else min(num_total, args.start_index + args.max_examples)
+    selected = data[args.start_index : stop_index]
+    logger.info("Dataset total=%d, selected=%d, start_index=%d", num_total, len(selected), args.start_index)
+
+    model, tokenizer = init_model(model_path, dtype_from_name(args.torch_dtype))
+    point_config = model.get_model().point_backbone_config
+    logger.info("Point backbone config: %s", point_config)
+
+    predictions_path.parent.mkdir(parents=True, exist_ok=True)
+    skipped: collections.Counter[str] = collections.Counter()
+    type_stats: Dict[str, Dict[str, int]] = {}
+    invalid_outputs = 0
+    num_evaluated = 0
+    num_correct = 0
+    written_predictions = 0
+
+    with predictions_path.open("w", encoding="utf-8") as pred_f:
+        for dataset_index, example in enumerate(tqdm(selected, desc="evaluating"), start=args.start_index):
+            ex_id = example.get("id") or f"index_{dataset_index}"
+            meta = sidecar.get(ex_id)
+            question_type = (meta or {}).get("question_type", "unknown")
+            answer = str(example.get("answer", "")).strip().upper()
+            if answer not in {"A", "B", "C", "D"}:
+                skipped["invalid_answer"] += 1
+                continue
+            try:
+                point_path, point_cloud, object_id = get_or_create_point_cloud(
+                    example=example,
+                    sidecar=meta,
+                    partseg_root=args.partseg_root,
+                    cache_dir=args.cache_dir,
+                    point_scope=args.point_scope,
+                    pointnum=args.pointnum,
+                    seed=args.seed,
+                )
+            except Exception as exc:
+                skipped[f"point_cloud_error:{type(exc).__name__}"] += 1
+                logger.warning("Skipping %s due to point-cloud error: %s", ex_id, exc)
+                continue
+            try:
+                input_ids = build_input_ids(
+                    example["prompt"],
+                    model,
+                    tokenizer,
+                    args.conv_mode,
+                    prompt_suffix=args.prompt_suffix,
+                    system_prompt=args.system_prompt,
+                )
+                choice_scores = None
+                if args.answer_mode == "constrained_generate":
+                    raw = generate_one_constrained_choice(
+                        model=model,
+                        tokenizer=tokenizer,
+                        input_ids=input_ids,
+                        point_cloud=point_cloud,
+                    )
+                elif args.answer_mode == "choice_logits":
+                    raw, choice_scores = predict_choice_from_logits(
+                        model=model,
+                        tokenizer=tokenizer,
+                        input_ids=input_ids,
+                        point_cloud=point_cloud,
+                    )
+                else:
+                    raw = generate_one(
+                        model=model,
+                        tokenizer=tokenizer,
+                        input_ids=input_ids,
+                        point_cloud=point_cloud,
+                        max_new_tokens=args.max_new_tokens,
+                        conv_mode=args.conv_mode,
+                    )
+            except Exception as exc:
+                skipped[f"inference_error:{type(exc).__name__}"] += 1
+                logger.exception("Skipping %s due to inference error", ex_id)
+                continue
+
+            prediction = parse_prediction(raw, example.get("prompt"))
+            invalid = prediction == "unknown"
+            if invalid:
+                invalid_outputs += 1
+            correct = prediction == answer
+            response_token_len = len(tokenizer.encode(raw, add_special_tokens=False))
+            max_response_len = 1 if args.answer_mode == "constrained_generate" else args.max_new_tokens
+            num_evaluated += 1
+            num_correct += int(correct)
+            update_type_stats(type_stats, question_type, correct, invalid)
+            record = {
+                "id": ex_id,
+                "dataset_index": dataset_index,
+                "object_id": object_id,
+                "question_type": question_type,
+                "answer": answer,
+                "prediction_raw": raw,
+                "prediction": prediction,
+                "correct": correct,
+                "response_token_len": response_token_len,
+                "hit_max_response_length": bool(response_token_len >= max_response_len),
+                "answer_mode": args.answer_mode,
+                "prompt_suffix": args.prompt_suffix,
+                "system_prompt": args.system_prompt,
+                "choice_scores": choice_scores,
+                "prompt": example.get("prompt"),
+                "point_path": str(point_path),
+                "point_scope": args.point_scope,
+                "model_path": str(model_path),
+                "image_path": example.get("image_path"),
+            }
+            pred_f.write(json.dumps(record, ensure_ascii=False) + "\n")
+            pred_f.flush()
+            written_predictions += 1
+            logger.info(
+                "id=%s qtype=%s answer=%s prediction=%s correct=%s raw=%r",
+                ex_id,
+                question_type,
+                answer,
+                prediction,
+                correct,
+                raw,
+            )
+
+    accuracy_by_type: Dict[str, Dict[str, Any]] = {}
+    for question_type, row in type_stats.items():
+        accuracy_by_type[question_type] = {
+            **row,
+            "accuracy": pct(row["num_correct"], row["num_evaluated"]),
+        }
+
+    runtime = time.time() - start_time
+    metrics = {
+        "model_path": str(model_path),
+        "dataset_path": str(args.dataset_path),
+        "sidecar_path": str(args.sidecar_path),
+        "partseg_root": str(args.partseg_root),
+        "command": command,
+        "num_total": num_total,
+        "num_selected": len(selected),
+        "start_index": args.start_index,
+        "max_examples": args.max_examples,
+        "num_evaluated": num_evaluated,
+        "num_predictions_written": written_predictions,
+        "num_correct": num_correct,
+        "accuracy": pct(num_correct, num_evaluated),
+        "accuracy_by_question_type": accuracy_by_type,
+        "skipped": dict(skipped),
+        "invalid_outputs": invalid_outputs,
+        "point_preprocessing": (
+            f"Derived from local PhysXNet OBJ files with scope={args.point_scope}; "
+            f"sampled {args.pointnum} surface points per object using seed={args.seed}; "
+            "coordinates normalized to unit sphere; RGB channels set to zero; "
+            f"cache stored under {args.cache_dir}."
+        ),
+        "pointnum": args.pointnum,
+        "seed": args.seed,
+        "torch_dtype": args.torch_dtype,
+        "answer_mode": args.answer_mode,
+        "prompt_suffix": args.prompt_suffix,
+        "system_prompt": args.system_prompt,
+        "max_new_tokens": args.max_new_tokens,
+        "runtime_seconds": runtime,
+        "predictions_path": str(predictions_path),
+        "metrics_path": str(metrics_path),
+        "report_path": str(report_path),
+        "log_path": str(args.log_path),
+        "created_utc": dt.datetime.utcnow().isoformat(timespec="seconds") + "Z",
+        "runtime_notes_and_known_limitations": [
+            "This is a preliminary local evaluation, not a fixed public benchmark result.",
+            "The PNG image_path field was not used as model input; PointLLM received derived point clouds.",
+            "The default point cloud represents the full object by concatenating all local part OBJ files.",
+            "OBJ geometry has no reliable color, so zero RGB channels were appended because this checkpoint expects 6D points.",
+            "Question types are recovered from the local JSONL sidecar when available.",
+            "Default answer_mode=freeform follows the VERL/TTRL pattern: use the MCQ prompt, generate normally, then parse an A/B/C/D option letter.",
+            "Default prompt_suffix is empty to match the VERL-style prompt, which ends after option D before the assistant response.",
+            "prediction_raw preserves the model's unnormalized free-form response; prediction is the parsed A/B/C/D answer used for scoring.",
+            "Unparsable model outputs are counted as incorrect and included in invalid_outputs.",
+            "constrained_generate and choice_logits remain available as stricter ablations, but are not the default.",
+            "No training, fine-tuning, downloads, external APIs, or original dataset modifications are performed by this script.",
+        ],
+    }
+    write_json(metrics_path, metrics)
+    report_path.write_text(render_report(metrics), encoding="utf-8")
+    logger.info("Wrote predictions: %s", predictions_path)
+    logger.info("Wrote metrics: %s", metrics_path)
+    logger.info("Wrote report: %s", report_path)
+    logger.info(
+        "Finished: evaluated=%d correct=%d accuracy=%.6f invalid=%d skipped=%s runtime=%.2fs",
+        num_evaluated,
+        num_correct,
+        metrics["accuracy"],
+        invalid_outputs,
+        dict(skipped),
+        runtime,
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
