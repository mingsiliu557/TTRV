+#!/usr/bin/env python
+"""Evaluate local PointLLM on the PhysXNet-derived MCQ dataset.
+
+This script is intentionally evaluation-only: it reads local MCQ/OBJ/model
+files, derives lightweight point-cloud caches under outputs/, and writes
+predictions plus aggregate metrics.
+"""
+
+from __future__ import annotations
+
+import argparse
+import collections
+import datetime as dt
+import hashlib
+import json
+import logging
+import os
+import re
+import shlex
+import sys
