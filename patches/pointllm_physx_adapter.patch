+#!/usr/bin/env python3
+"""Prepare PhysXNet MCQ data for PointLLM veRL/TTRV runs.
+
+This script only reads local PhysX JSON/OBJ files, writes parquet files under an
+experiment output directory, and reuses the PointLLM OBJ-to-point-cache logic.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from pathlib import Path
+from typing import Any
+
+os.environ.setdefault("HF_HUB_OFFLINE", "1")
+os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
+os.environ.setdefault("HF_DATASETS_OFFLINE", "1")
+
+import numpy as np
+from datasets import Dataset
+
+SCRIPT_DIR = Path(__file__).resolve().parent
+POINTLLM_ROOT = SCRIPT_DIR.parents[0]
+if str(POINTLLM_ROOT) not in sys.path:
+    sys.path.insert(0, str(POINTLLM_ROOT))
+if str(SCRIPT_DIR) not in sys.path:
+    sys.path.insert(0, str(SCRIPT_DIR))
+
+from eval_physx_mcq_pointllm import (  # noqa: E402
+    DEFAULT_DATASET,
+    DEFAULT_PARTSEG_ROOT,
+    DEFAULT_SIDECAR,
+    get_or_create_point_cloud,
+    read_dataset,
+    read_sidecar,
+    target_part_label_from_example,
+)
+
+POINT_TOKEN_LEN = 513
+DEFAULT_POINT_PROMPT_NOTES = (
+    "PhysXNet OBJ -> sampled surface points -> unit-sphere XYZ normalization -> zero RGB channels. "
+    "PNG image_path is retained only as metadata and is not used as point input."
+)
+
+
+def point_tokens(point_token_len: int) -> str:
+    return "<point_start>" + ("<point_patch>" * point_token_len) + "<point_end>"
+
+
+def build_prompt(raw_prompt: str, point_token_len: int, prompt_suffix: str = "") -> str:
+    prompt = str(raw_prompt).strip()
+    prompt = prompt.replace("<image>", point_tokens(point_token_len), 1)
+    suffix = prompt_suffix.strip()
+    if suffix and not prompt.endswith(suffix):
+        prompt = f"{prompt}\n{suffix}"
+    return prompt
+
+
+def split_csv_set(value: str) -> set[str]:
+    return {part.strip() for part in str(value or "").split(",") if part.strip()}
+
+
+def select_indices(
+    data: list[dict[str, Any]],
+    sidecar: dict[str, dict[str, Any]],
+    start: int,
+    limit: int | None,
+    selection: str,
+    seed: int,
+    question_type_filter: set[str] | None = None,
+) -> list[int]:
+    if limit is not None and limit < 0:
+        limit = len(data) - start
+    candidates = []
+    for idx in range(max(start, 0), len(data)):
+        if question_type_filter:
+            ex_id = data[idx].get("id") or f"index_{idx}"
+            qtype = str((sidecar.get(ex_id) or {}).get("question_type", "unknown"))
+            if qtype not in question_type_filter:
+                continue
+        candidates.append(idx)
+    if selection == "first":
+        return candidates[:limit] if limit is not None else candidates
+
+    rng = np.random.default_rng(seed)
+    if selection == "random":
+        shuffled = candidates[:]
+        rng.shuffle(shuffled)
+        return shuffled[:limit] if limit is not None else shuffled
+
+    by_type: dict[str, list[int]] = {}
+    for idx in candidates:
+        ex_id = data[idx].get("id") or f"index_{idx}"
+        qtype = (sidecar.get(ex_id) or {}).get("question_type", "unknown")
+        by_type.setdefault(str(qtype), []).append(idx)
+    for values in by_type.values():
+        rng.shuffle(values)
+    selected: list[int] = []
+    keys = sorted(by_type)
+    while keys and (limit is None or len(selected) < limit):
+        next_keys = []
+        for key in keys:
+            values = by_type[key]
+            if values and (limit is None or len(selected) < limit):
+                selected.append(values.pop())
+            if values:
+                next_keys.append(key)
+        keys = next_keys
+    return selected
+
+
+def build_rows(
+    data: list[dict[str, Any]],
+    sidecar: dict[str, dict[str, Any]],
+    indices: list[int],
+    split: str,
+    args: argparse.Namespace,
+) -> list[dict[str, Any]]:
+    rows = []
+    skipped: dict[str, int] = {}
+    for row_index, dataset_index in enumerate(indices):
+        example = data[dataset_index]
+        ex_id = example.get("id") or f"index_{dataset_index}"
+        meta = sidecar.get(ex_id) or {}
+        answer = str(example.get("answer", "")).strip().upper()
+        if answer not in {"A", "B", "C", "D"}:
+            skipped["invalid_answer"] = skipped.get("invalid_answer", 0) + 1
+            continue
+        try:
+            point_path, point_cloud, object_id = get_or_create_point_cloud(
+                example=example,
+                sidecar=meta,
+                partseg_root=args.partseg_root,
+                cache_dir=args.cache_dir,
+                point_scope=args.point_scope,
+                pointnum=args.pointnum,
+                seed=args.seed,
+            )
+        except Exception as exc:
+            key = f"point_cloud_error:{type(exc).__name__}"
+            skipped[key] = skipped.get(key, 0) + 1
+            print(f"[prepare_physx_mcq] skip id={ex_id} error={exc}", file=sys.stderr)
+            continue
+        if point_cloud.shape != (args.pointnum, 6):
+            raise ValueError(f"Expected point cloud shape ({args.pointnum}, 6), got {point_cloud.shape} for {point_path}")
+        question_type = str(meta.get("question_type", "unknown"))
+        prompt = build_prompt(example.get("prompt", ""), point_token_len=args.point_token_len, prompt_suffix=args.prompt_suffix)
+        extra_info = {
+            "id": ex_id,
+            "index": ex_id,
+            "dataset_index": int(dataset_index),
+            "row_index": int(row_index),
+            "split": split,
+            "object_id": str(object_id),
+            "question_type": question_type,
+            "answer": answer,
+            "pc_path": str(point_path),
+            "point_path": str(point_path),
+            "point_scope": args.point_scope,
+            "pointnum": int(args.pointnum),
+            "seed": int(args.seed),
+            "target_part_label": target_part_label_from_example(example, meta),
+            "image_path": example.get("image_path"),
+            "source": example.get("source"),
+            "answer_text": meta.get("answer_text") or meta.get("target_answer"),
+            "point_preprocessing": DEFAULT_POINT_PROMPT_NOTES,
+            "prompt_suffix": args.prompt_suffix,
+            "prompt_version": "physx_mcq_pointllm_abcd_v1" + ("_suffix" if args.prompt_suffix.strip() else ""),
+        }
+        rows.append(
+            {
+                "data_source": "physx_mcq",
+                "prompt": [{"role": "user", "content": prompt}],
+                "ability": "3d_mcq",
+                "reward_model": {"style": "rule", "ground_truth": answer},
+                "extra_info": extra_info,
+            }
+        )
+    if skipped:
+        print(f"[prepare_physx_mcq] skipped {json.dumps(skipped, sort_keys=True)}", file=sys.stderr)
+    return rows
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--dataset-path", type=Path, default=DEFAULT_DATASET)
+    parser.add_argument("--sidecar-path", type=Path, default=DEFAULT_SIDECAR)
+    parser.add_argument("--partseg-root", type=Path, default=DEFAULT_PARTSEG_ROOT)
+    parser.add_argument("--output-dir", type=Path, required=True)
+    parser.add_argument("--cache-dir", type=Path, default=POINTLLM_ROOT / "outputs" / "physxnet_point_cache")
+    parser.add_argument("--train-subset", type=int, default=20)
+    parser.add_argument("--val-subset", type=int, default=20, help="Use -1 for all remaining examples.")
+    parser.add_argument("--train-start-index", type=int, default=0)
+    parser.add_argument("--val-start-index", type=int, default=0)
+    parser.add_argument("--selection", choices=["first", "random", "stratified"], default="first")
+    parser.add_argument(
+        "--question-type-filter",
+        default="",
+        help="Optional comma-separated PhysX question_type filter, e.g. object_category,joint_type.",
+    )
+    parser.add_argument("--seed", type=int, default=0)
+    parser.add_argument("--pointnum", type=int, default=8192)
+    parser.add_argument("--point-scope", choices=["full_object", "target_part"], default="full_object")
+    parser.add_argument("--point-token-len", type=int, default=POINT_TOKEN_LEN)
+    parser.add_argument("--prompt-suffix", default="")
+    parser.add_argument("--overwrite", action="store_true")
+    args = parser.parse_args()
+
+    output_dir = args.output_dir.expanduser().resolve()
+    train_path = output_dir / "train.parquet"
+    test_path = output_dir / "test.parquet"
+    manifest_path = output_dir / "manifest.json"
+    if not args.overwrite and (train_path.exists() or test_path.exists()):
+        raise FileExistsError(f"Refusing to overwrite existing parquet files under {output_dir}; pass --overwrite")
+
+    data = read_dataset(args.dataset_path)
+    sidecar = read_sidecar(args.sidecar_path)
+    question_type_filter = split_csv_set(args.question_type_filter)
+    train_indices = select_indices(
+        data,
+        sidecar,
+        args.train_start_index,
+        args.train_subset,
+        args.selection,
+        args.seed,
+        question_type_filter=question_type_filter,
+    )
+    val_limit = None if args.val_subset < 0 else args.val_subset
+    val_indices = select_indices(
+        data,
+        sidecar,
+        args.val_start_index,
+        val_limit,
+        args.selection,
+        args.seed + 1,
+        question_type_filter=question_type_filter,
+    )
+
+    args.cache_dir.mkdir(parents=True, exist_ok=True)
+    output_dir.mkdir(parents=True, exist_ok=True)
+    train_rows = build_rows(data, sidecar, train_indices, "train", args)
+    test_rows = build_rows(data, sidecar, val_indices, "test", args)
+    Dataset.from_list(train_rows).to_parquet(str(train_path))
+    Dataset.from_list(test_rows).to_parquet(str(test_path))
+
+    type_counts = {"train": {}, "test": {}}
+    for split, rows in (("train", train_rows), ("test", test_rows)):
+        counts: dict[str, int] = {}
+        for row in rows:
+            qtype = row["extra_info"].get("question_type", "unknown")
+            counts[qtype] = counts.get(qtype, 0) + 1
+        type_counts[split] = dict(sorted(counts.items()))
+
+    manifest = {
+        "dataset_path": str(args.dataset_path),
+        "sidecar_path": str(args.sidecar_path),
+        "partseg_root": str(args.partseg_root),
+        "train_path": str(train_path),
+        "test_path": str(test_path),
+        "num_train": len(train_rows),
+        "num_test": len(test_rows),
+        "question_type_counts": type_counts,
+        "point_scope": args.point_scope,
+        "pointnum": args.pointnum,
+        "seed": args.seed,
+        "cache_dir": str(args.cache_dir),
+        "point_token_len": args.point_token_len,
+        "point_preprocessing": DEFAULT_POINT_PROMPT_NOTES,
+        "selection": args.selection,
+        "question_type_filter": sorted(question_type_filter),
+        "prompt_suffix": args.prompt_suffix,
+    }
+    manifest_path.write_text(json.dumps(manifest, ensure_ascii=False, indent=2), encoding="utf-8")
+    print(json.dumps(manifest, ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
