+    (args.output_dir / "manifest.json").write_text(json.dumps(manifest, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+    lines = [
+        f"# Rollout-Reliable Adapt-{args.limit}: {args.question_type}",
+        "",
+        "Selection rule: frozen 8-sample audit majority is correct, Geo soft selected, sufficient GT mass, low invalid/hitmax.",
+        "",
+        "| pos | id | answer | option text | resp_acc | maj_ratio | gt_mass | hm | object_id |",
+        "| ---: | --- | --- | --- | ---: | ---: | ---: | ---: | --- |",
