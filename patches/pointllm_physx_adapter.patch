+#!/usr/bin/env python3
+"""Build an adaptation parquet from rollout-reliable MCQ audit predictions."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+from collections import Counter, defaultdict
+from pathlib import Path
+from typing import Any
+
+import pandas as pd
+
+
+CHOICES = {"A", "B", "C", "D"}
+OPTION_RE = re.compile(r"(?m)^([A-D])\.\s*(.+)$")
+
+
+def read_jsonl(path: Path) -> list[dict[str, Any]]:
+    rows = []
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line.strip():
+                rows.append(json.loads(line))
+    return rows
+
+
+def extra(row: pd.Series) -> dict[str, Any]:
+    value = row.get("extra_info")
+    return value if isinstance(value, dict) else {}
+
+
+def row_id(row: pd.Series) -> str:
+    info = extra(row)
+    return str(info.get("id") or info.get("index") or "")
+
+
+def row_qtype(row: pd.Series) -> str:
+    return str(extra(row).get("question_type") or "")
+
+
+def row_answer(row: pd.Series) -> str:
+    reward = row.get("reward_model")
+    if isinstance(reward, dict) and reward.get("ground_truth"):
+        return str(reward.get("ground_truth")).strip().upper()
+    return str(extra(row).get("answer") or "").strip().upper()
+
+
+def prompt_content(row: pd.Series) -> str:
+    value = row.get("prompt")
+    if isinstance(value, list) and value and isinstance(value[0], dict):
+        return str(value[0].get("content") or "")
+    try:
+        if len(value) and isinstance(value[0], dict):
+            return str(value[0].get("content") or "")
+    except Exception:
+        pass
+    return str(value)
+
+
+def correct_option_text(row: pd.Series) -> str:
+    answer = row_answer(row)
+    options = dict(OPTION_RE.findall(prompt_content(row)))
+    return str(options.get(answer) or "").strip()
+
+
+def group_audit_predictions(path: Path, qtype: str) -> dict[str, dict[str, Any]]:
+    groups: dict[str, list[dict[str, Any]]] = defaultdict(list)
+    for pred in read_jsonl(path):
+        if qtype and str(pred.get("question_type") or "") != qtype:
+            continue
+        key = str(pred.get("id") or pred.get("index") or "")
+        if key:
+            groups[key].append(pred)
+
+    out: dict[str, dict[str, Any]] = {}
+    for key, rows in groups.items():
+        first = rows[0]
+        corrects = [float(row.get("correct") or row.get("acc") or 0.0) for row in rows]
+        preds = [str(row.get("prediction") or row.get("pred") or "").strip() for row in rows]
+        pred_counts = Counter(preds)
+        majority_prediction, majority_count = pred_counts.most_common(1)[0]
+        invalid_rate = sum(1 for pred in preds if pred == "unknown") / len(rows)
+        hit_rate = sum(1 for row in rows if bool(row.get("hit_max_response_length"))) / len(rows)
+        answer = str(first.get("answer") or "").strip().upper()
+        out[key] = {
+            "id": key,
+            "answer": answer,
+            "votes": len(rows),
+            "response_accuracy": sum(corrects) / len(corrects),
+            "pass_at_votes": float(any(corrects)),
+            "majority_prediction": majority_prediction,
+            "majority_accuracy": float(majority_prediction == answer),
+            "majority_count": majority_count,
+            "majority_ratio": majority_count / len(rows),
+            "invalid_rate": invalid_rate,
+            "hit_max_response_length_rate": hit_rate,
+            "geo_soft_selected": float(first.get("geo_soft_selected") or 0.0),
+            "geo_soft_gt_mass": float(first.get("geo_soft_gt_mass") or 0.0),
+            "geo_soft_top_prob": float(first.get("geo_soft_top_prob") or 0.0),
+            "geo_harmony_hm": float(first.get("geo_harmony_hm") or 0.0),
+            "prediction_distribution": dict(pred_counts),
+        }
+    return out
+
+
+def audit_reliable(audit: dict[str, Any], args: argparse.Namespace) -> bool:
+    return (
+        audit["answer"] in CHOICES
+        and audit["majority_accuracy"] >= 1.0
+        and audit["pass_at_votes"] >= 1.0
+        and audit["response_accuracy"] >= args.min_response_accuracy
+        and audit["majority_ratio"] >= args.min_majority_ratio
+        and audit["geo_soft_selected"] >= args.min_geo_soft_selected
+        and audit["geo_soft_gt_mass"] >= args.min_geo_soft_gt_mass
+        and audit["invalid_rate"] <= args.max_invalid_rate
+        and audit["hit_max_response_length_rate"] <= args.max_hitmax_rate
+    )
+
+
+def quality_key(item: tuple[int, pd.Series, dict[str, Any]]) -> tuple[Any, ...]:
+    idx, row, audit = item
+    info = extra(row)
+    return (
+        -audit["response_accuracy"],
+        -audit["geo_soft_gt_mass"],
+        -audit["majority_ratio"],
+        -audit["geo_harmony_hm"],
+        audit["hit_max_response_length_rate"],
+        str(info.get("object_id") or ""),
+        int(info.get("dataset_index") or idx),
+    )
+
+
+def select_balanced_diverse(
+    candidates: list[tuple[int, pd.Series, dict[str, Any]]],
+    limit: int,
+) -> list[tuple[int, pd.Series, dict[str, Any]]]:
+    by_answer: dict[str, list[tuple[int, pd.Series, dict[str, Any]]]] = {choice: [] for choice in sorted(CHOICES)}
+    for item in candidates:
+        answer = row_answer(item[1])
+        if answer in by_answer:
+            by_answer[answer].append(item)
+    for answer in by_answer:
+        by_answer[answer].sort(key=quality_key)
+
+    selected: list[tuple[int, pd.Series, dict[str, Any]]] = []
+    selected_ids: set[str] = set()
+    selected_objects: Counter[str] = Counter()
+    selected_texts: Counter[str] = Counter()
+    answer_counts: Counter[str] = Counter()
+
+    while len(selected) < limit:
+        available_answers = [answer for answer, values in by_answer.items() if values]
+        if not available_answers:
+            break
+        answer = min(available_answers, key=lambda value: (answer_counts[value], value))
+        values = by_answer[answer]
+        best_pos = 0
+        best_key = None
+        for pos, item in enumerate(values[:200]):
+            rid = row_id(item[1])
+            if rid in selected_ids:
+                continue
+            obj = str(extra(item[1]).get("object_id") or "")
+            text = correct_option_text(item[1]).strip().lower()
+            key = (
+                selected_texts[text],
+                selected_objects[obj],
+                quality_key(item),
+            )
+            if best_key is None or key < best_key:
+                best_key = key
+                best_pos = pos
+        item = values.pop(best_pos)
+        rid = row_id(item[1])
+        if rid in selected_ids:
+            continue
+        selected.append(item)
+        selected_ids.add(rid)
+        answer_counts[row_answer(item[1])] += 1
+        selected_objects[str(extra(item[1]).get("object_id") or "")] += 1
+        selected_texts[correct_option_text(item[1]).strip().lower()] += 1
+    return selected
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--source-data-dir", type=Path, required=True)
+    parser.add_argument("--audit-jsonl", type=Path, required=True)
+    parser.add_argument("--output-dir", type=Path, required=True)
