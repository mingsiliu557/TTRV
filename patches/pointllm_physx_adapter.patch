+#!/usr/bin/env python3
+"""Build per-question-type parquet curricula from reliable step0 predictions.
+
+The script keeps validation full-size for the selected question type, and only
+reorders the training parquet so that the first N rows are reliable adaptation
+examples. It does not modify any source dataset.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+from collections import Counter
+from pathlib import Path
+from typing import Any
+
+import pandas as pd
+
+
+CHOICES = {"A", "B", "C", "D"}
+OPTION_RE = re.compile(r"(?m)^([A-D])\.\s*(.+)$")
+
+
+def read_jsonl(path: Path) -> list[dict[str, Any]]:
+    rows = []
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line.strip():
+                rows.append(json.loads(line))
+    return rows
+
+
+def extra(row: pd.Series) -> dict[str, Any]:
+    value = row.get("extra_info")
+    return value if isinstance(value, dict) else {}
+
+
+def row_id(row: pd.Series) -> str:
+    info = extra(row)
+    return str(info.get("id") or info.get("index") or "")
+
+
+def row_qtype(row: pd.Series) -> str:
+    return str(extra(row).get("question_type") or "")
+
+
+def row_answer(row: pd.Series) -> str:
+    reward = row.get("reward_model")
+    if isinstance(reward, dict) and reward.get("ground_truth"):
+        return str(reward.get("ground_truth")).strip().upper()
+    return str(extra(row).get("answer") or "").strip().upper()
+
+
+def prompt_content(row: pd.Series) -> str:
+    value = row.get("prompt")
+    try:
+        if len(value) and isinstance(value[0], dict):
+            return str(value[0].get("content") or "")
+    except Exception:
+        pass
+    if isinstance(value, list) and value and isinstance(value[0], dict):
+        return str(value[0].get("content") or "")
+    return str(value)
+
+
+def correct_option_text(row: pd.Series) -> str:
+    answer = row_answer(row)
+    options = dict(OPTION_RE.findall(prompt_content(row)))
+    return str(options.get(answer) or "").strip()
+
+
+def is_reliable(pred: dict[str, Any], answer: str, max_token_len: int) -> bool:
+    prediction = str(pred.get("prediction") or pred.get("pred") or "").strip().upper()
+    correct = pred.get("correct")
+    if correct is None:
+        correct = prediction == answer
+    token_len = pred.get("response_token_len")
+    try:
+        token_len_ok = int(token_len) <= max_token_len
+    except Exception:
+        token_len_ok = True
+    return (
+        prediction in CHOICES
+        and prediction == answer
+        and bool(correct)
+        and not bool(pred.get("hit_max_response_length"))
+        and token_len_ok
+    )
+
+
+def load_prediction_map(path: Path, qtype: str) -> dict[str, dict[str, Any]]:
+    out = {}
+    for pred in read_jsonl(path):
+        if qtype and str(pred.get("question_type") or "") != qtype:
+            continue
+        key = str(pred.get("index") or pred.get("id") or "")
+        if key:
+            out[key] = pred
+    return out
+
+
+def sort_key(item: tuple[int, pd.Series, dict[str, Any]]) -> tuple[Any, ...]:
+    idx, row, pred = item
+    info = extra(row)
+    raw = str(pred.get("prediction_raw") or "").strip()
+    answer = row_answer(row)
+    starts_with_answer = raw.upper().startswith(answer)
+    token_len = pred.get("response_token_len")
+    try:
+        token_len_i = int(token_len)
+    except Exception:
+        token_len_i = 999
+    return (
+        0 if starts_with_answer else 1,
+        token_len_i,
+        str(info.get("object_id") or ""),
+        int(info.get("dataset_index") or idx),
+    )
+
+
+def balanced_select(candidates: list[tuple[int, pd.Series, dict[str, Any]]], limit: int) -> list[tuple[int, pd.Series, dict[str, Any]]]:
+    by_answer: dict[str, list[tuple[int, pd.Series, dict[str, Any]]]] = {choice: [] for choice in sorted(CHOICES)}
+    for item in candidates:
+        answer = row_answer(item[1])
+        if answer in by_answer:
+            by_answer[answer].append(item)
+    for answer in by_answer:
+        by_answer[answer].sort(key=sort_key)
+
+    selected: list[tuple[int, pd.Series, dict[str, Any]]] = []
+    selected_ids: set[str] = set()
+    selected_objects: Counter[str] = Counter()
+    answer_counts: Counter[str] = Counter()
+
+    while len(selected) < limit:
+        available_answers = [a for a, values in by_answer.items() if values]
+        if not available_answers:
+            break
+        answer = min(available_answers, key=lambda a: (answer_counts[a], a))
+        values = by_answer[answer]
+        best_pos = 0
+        best_key = None
+        for pos, item in enumerate(values[:50]):
+            rid = row_id(item[1])
+            if rid in selected_ids:
+                continue
+            obj = str(extra(item[1]).get("object_id") or "")
+            key = (selected_objects[obj], sort_key(item))
+            if best_key is None or key < best_key:
+                best_key = key
+                best_pos = pos
+        item = values.pop(best_pos)
+        rid = row_id(item[1])
+        if rid in selected_ids:
+            continue
+        selected.append(item)
+        selected_ids.add(rid)
+        answer_counts[row_answer(item[1])] += 1
+        selected_objects[str(extra(item[1]).get("object_id") or "")] += 1
+    return selected
+
+
+def diverse_text_select(candidates: list[tuple[int, pd.Series, dict[str, Any]]], limit: int) -> list[tuple[int, pd.Series, dict[str, Any]]]:
+    by_answer: dict[str, list[tuple[int, pd.Series, dict[str, Any]]]] = {choice: [] for choice in sorted(CHOICES)}
+    for item in candidates:
+        answer = row_answer(item[1])
+        if answer in by_answer:
+            by_answer[answer].append(item)
+    for answer in by_answer:
+        by_answer[answer].sort(key=sort_key)
+
+    selected: list[tuple[int, pd.Series, dict[str, Any]]] = []
+    selected_ids: set[str] = set()
+    selected_objects: Counter[str] = Counter()
+    selected_texts: Counter[str] = Counter()
+    answer_counts: Counter[str] = Counter()
+
+    while len(selected) < limit:
+        available_answers = [a for a, values in by_answer.items() if values]
+        if not available_answers:
+            break
+        answer = min(available_answers, key=lambda a: (answer_counts[a], a))
+        values = by_answer[answer]
+        best_pos = 0
+        best_key = None
+        for pos, item in enumerate(values[:200]):
+            rid = row_id(item[1])
+            if rid in selected_ids:
+                continue
+            obj = str(extra(item[1]).get("object_id") or "")
+            text = correct_option_text(item[1]).strip().lower()
+            key = (
+                selected_texts[text],
+                selected_objects[obj],
+                sort_key(item),
+            )
+            if best_key is None or key < best_key:
+                best_key = key
+                best_pos = pos
+        item = values.pop(best_pos)
+        rid = row_id(item[1])
+        if rid in selected_ids:
+            continue
+        selected.append(item)
+        selected_ids.add(rid)
+        answer_counts[row_answer(item[1])] += 1
+        selected_objects[str(extra(item[1]).get("object_id") or "")] += 1
+        selected_texts[correct_option_text(item[1]).strip().lower()] += 1
+    return selected
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--source-data-dir", type=Path, required=True)
+    parser.add_argument("--prediction-jsonl", type=Path, required=True)
+    parser.add_argument("--output-dir", type=Path, required=True)
+    parser.add_argument("--question-type", required=True)
+    parser.add_argument("--limit", type=int, default=20)
+    parser.add_argument("--max-token-len", type=int, default=24)
+    parser.add_argument("--selection-name", default="step0_reliable20")
+    parser.add_argument("--strategy", choices=["balanced_shortest", "diverse_text"], default="balanced_shortest")
+    parser.add_argument(
+        "--test-mode",
+        choices=["full", "selected"],
+        default="full",
+        help="Use full question-type validation set, or only the selected reliable rows for candidate audits.",
+    )
+    args = parser.parse_args()
+
+    train_df = pd.read_parquet(args.source_data_dir / "train.parquet")
+    test_df = pd.read_parquet(args.source_data_dir / "test.parquet")
+    pred_map = load_prediction_map(args.prediction_jsonl, args.question_type)
+
+    train_q = train_df[train_df.apply(lambda row: row_qtype(row) == args.question_type, axis=1)].copy()
+    test_q = test_df[test_df.apply(lambda row: row_qtype(row) == args.question_type, axis=1)].copy()
+
+    candidates: list[tuple[int, pd.Series, dict[str, Any]]] = []
+    for idx, row in train_q.iterrows():
+        rid = row_id(row)
+        pred = pred_map.get(rid)
+        answer = row_answer(row)
+        if pred and is_reliable(pred, answer, args.max_token_len):
+            candidates.append((int(idx), row, pred))
+
+    if args.strategy == "diverse_text":
+        selected = diverse_text_select(candidates, args.limit)
+    else:
+        selected = balanced_select(candidates, args.limit)
+    selected_ids = [row_id(item[1]) for item in selected]
+    selected_set = set(selected_ids)
+    if len(selected) < args.limit:
+        raise RuntimeError(f"Only selected {len(selected)} reliable rows for {args.question_type}; need {args.limit}")
+
+    selected_df = train_q[train_q.apply(lambda row: row_id(row) in selected_set, axis=1)].copy()
+    selected_df["_selection_order"] = selected_df.apply(lambda row: selected_ids.index(row_id(row)), axis=1)
+    selected_df = selected_df.sort_values("_selection_order").drop(columns=["_selection_order"])
+    rest_df = train_q[~train_q.apply(lambda row: row_id(row) in selected_set, axis=1)].copy()
+    out_train = pd.concat([selected_df, rest_df], ignore_index=True)
+    if args.test_mode == "selected":
+        out_test = selected_df.reset_index(drop=True)
+    else:
+        out_test = test_q.reset_index(drop=True)
+
+    args.output_dir.mkdir(parents=True, exist_ok=True)
+    out_train.to_parquet(args.output_dir / "train.parquet", index=False)
+    out_test.to_parquet(args.output_dir / "test.parquet", index=False)
+
+    selected_records = []
+    for pos, (_idx, row, pred) in enumerate(selected):
+        info = extra(row)
+        selected_records.append(
+            {
+                "pos": pos,
+                "id": row_id(row),
+                "question_type": args.question_type,
+                "answer": row_answer(row),
+                "prediction": str(pred.get("prediction") or pred.get("pred") or ""),
+                "response_token_len": pred.get("response_token_len"),
+                "prediction_raw": pred.get("prediction_raw"),
+                "object_id": info.get("object_id"),
+                "answer_text": info.get("answer_text"),
+                "correct_option_text": correct_option_text(row),
+                "dataset_index": info.get("dataset_index"),
+            }
+        )
+
+    manifest = {
+        "selection_name": args.selection_name,
+        "question_type": args.question_type,
+        "source_data_dir": str(args.source_data_dir),
+        "prediction_jsonl": str(args.prediction_jsonl),
+        "output_dir": str(args.output_dir),
+        "train_rows": int(len(out_train)),
+        "test_rows": int(len(out_test)),
+        "candidate_rows": int(len(candidates)),
+        "selected_rows": int(len(selected)),
+        "selected_answer_counts": dict(Counter(record["answer"] for record in selected_records)),
+        "max_token_len": int(args.max_token_len),
+        "strategy": args.strategy,
+        "test_mode": args.test_mode,
+        "oracle_ground_truth_used_for_reliability": True,
+        "selected": selected_records,
+    }
+    (args.output_dir / "manifest.json").write_text(json.dumps(manifest, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+    lines = [
+        f"# Reliable Step0 Adapt-{args.limit}: {args.question_type}",
+        "",
+        f"Selection rule: step0 correct, parsed A/B/C/D, non-hitmax, response_token_len within threshold; strategy={args.strategy}.",
+        "",
+        "| pos | id | answer | option text | tokens | object_id | raw |",
+        "| ---: | --- | --- | --- | ---: | --- | --- |",
+    ]
+    for rec in selected_records:
+        raw = str(rec.get("prediction_raw") or "").replace("|", "\\|")
+        text = str(rec.get("correct_option_text") or "").replace("|", "\\|")
+        lines.append(
+            f"| {rec['pos']} | {rec['id']} | {rec['answer']} | {text} | {rec.get('response_token_len')} | {rec.get('object_id')} | {raw} |"
+        )
+    (args.output_dir / f"{args.selection_name}_{args.question_type}.md").write_text("\n".join(lines) + "\n", encoding="utf-8")
+    print(json.dumps(manifest, ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
