+++ b/scripts/build_physx_cleaned_options_v2_candidates.py
@@ -0,0 +1,470 @@
+#!/usr/bin/env python3
+"""Build data-side PhysX-MCQ v2 candidate subsets.
+
+These candidates keep the existing VERL/sidecar schema and write new files under
+outputs/. They are intended for data-quality experiments, not for changing the
+original PhysXNet data.
+"""
+
+from __future__ import annotations
+
+import argparse
+import collections
+import hashlib
+import json
+import random
+import re
+from pathlib import Path
+from typing import Any
+
+LETTERS = "ABCD"
+
+TTRV_ROOT = Path(__file__).resolve().parents[2]
+DEFAULT_V1_DIR = TTRV_ROOT / "outputs" / "physx_cleaned_options_v1"
+DEFAULT_OUTPUT_DIR = TTRV_ROOT / "outputs" / "physx_cleaned_options_v2_candidates"
+DEFAULT_V1_VERL = DEFAULT_V1_DIR / "physxnet_mcq_verl_cleaned_options.json"
+DEFAULT_V1_SIDECAR = DEFAULT_V1_DIR / "physxnet_mcq_cleaned_options.jsonl"
+DEFAULT_STEP0 = DEFAULT_V1_DIR / "fixed_step0_caches" / "combined_validation_predictions_step0.jsonl"
+
+JOINT_PLAIN_OPTIONS = [
+    "stationary or fixed joint (no relative motion)",
+    "sliding joint (linear motion)",
+    "rotating hinge joint",
+    "combined sliding and rotating joint",
+]
+JOINT_RAW_TO_PLAIN = {
+    "A": "stationary or fixed joint (no relative motion)",
+    "E": "stationary or fixed joint (no relative motion)",
+    "B": "sliding joint (linear motion)",
+    "C": "rotating hinge joint",
+    "D": "rotating hinge joint",
+    "CB": "combined sliding and rotating joint",
+}
+
+VISIBLE_PART_TERMS = {
+    "button",
+    "cabinet door",
+    "cover",
+    "cover lid",
+    "display",
+    "display screen",
+    "door",
+    "drawer",
+    "handle",
+    "hose",
+    "hour hand",
+    "lamp head",
+    "lid",
+    "light bulb",
+    "minute hand",
+    "screen",
+    "spout",
+    "switch",
+}
+BAD_PART_TERMS = {
+    "book",
+    "liquid",
+    "plant",
+    "pillow",
+    "soil",
+}
+GENERIC_PART_RE = re.compile(r"\b(surface|support|base|bar|connector|panel|other|component)\b", re.I)
+
+
+def read_json(path: Path) -> Any:
+    with path.open("r", encoding="utf-8") as handle:
+        return json.load(handle)
+
+
+def read_jsonl(path: Path) -> list[dict[str, Any]]:
+    rows = []
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line.strip():
+                rows.append(json.loads(line))
+    return rows
+
+
+def write_json(path: Path, payload: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+
+def write_jsonl(path: Path, rows: list[dict[str, Any]]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("w", encoding="utf-8") as handle:
+        for row in rows:
+            handle.write(json.dumps(row, ensure_ascii=False) + "\n")
+
+
+def normalize_text(value: Any) -> str:
+    return re.sub(r"[^a-z0-9]+", " ", str(value or "").lower()).strip()
+
+
+def display_part_label(value: Any) -> str:
+    text = str(value or "").strip()
+    text = re.sub(r"^\d+[_\-\s]+", "", text)
+    text = text.replace("_", " ")
+    text = re.sub(r"\s+", " ", text).strip()
+    return text
+
+
+def stable_shuffle(values: list[str], key: str, seed: int) -> list[str]:
+    shuffled = values[:]
+    digest = hashlib.sha256(f"{seed}:{key}".encode("utf-8")).hexdigest()
+    rng = random.Random(int(digest[:16], 16))
+    rng.shuffle(shuffled)
+    return shuffled
+
+
+def render_prompt(question: str, choices: list[str]) -> str:
+    lines = [
+        "<image> ",
+        (
+            f"{question} Choose the correct answer from the options below and respond with only the "
+            "corresponding option letter (A, B, C, or D). Do not include any explanation or extra text. "
+        ),
+        "Options:",
+    ]
+    lines.extend(f"{letter}. {choice}" for letter, choice in zip(LETTERS, choices))
+    return "\n".join(lines)
+
+
+def is_visible_part_label(text: Any) -> bool:
+    norm = normalize_text(text)
+    return any(term in norm for term in VISIBLE_PART_TERMS)
+
+
+def is_bad_part_label(text: Any) -> bool:
+    norm = normalize_text(text)
+    return any(term in norm for term in BAD_PART_TERMS)
+
+
+def generic_choice_count(choices: list[str]) -> int:
+    return sum(1 for choice in choices if GENERIC_PART_RE.search(choice))
+
+
+def load_prediction_map(path: Path) -> dict[str, dict[str, Any]]:
+    if not path.exists():
+        return {}
+    return {str(row.get("index") or row.get("id")): row for row in read_jsonl(path)}
+
+
+def retained_estimate(rows: list[dict[str, Any]], predictions: dict[str, dict[str, Any]]) -> dict[str, Any]:
+    total = 0
+    correct = 0
+    invalid = 0
+    hitmax = 0
+    by_qtype: dict[str, collections.Counter[str]] = collections.defaultdict(collections.Counter)
+    by_reason: dict[str, collections.Counter[str]] = collections.defaultdict(collections.Counter)
+    for row in rows:
+        pred = predictions.get(str(row.get("id")))
+        if pred is None:
+            continue
+        total += 1
+        prediction = str(pred.get("prediction") or pred.get("pred") or "unknown")
+        cleaning_v2 = (row.get("source") or {}).get("cleaning_v2") or {}
+        answer = str(cleaning_v2.get("original_v1_answer_letter") or LETTERS[int(row["answer_index"])])
+        is_correct = prediction == answer
+        is_invalid = prediction == "unknown"
+        is_hitmax = bool(pred.get("hit_max_response_length"))
+        correct += int(is_correct)
+        invalid += int(is_invalid)
+        hitmax += int(is_hitmax)
+        for key in (str(row.get("question_type") or "unknown"),):
+            by_qtype[key]["n"] += 1
+            by_qtype[key]["correct"] += int(is_correct)
+            by_qtype[key]["invalid"] += int(is_invalid)
+            by_qtype[key]["hitmax"] += int(is_hitmax)
+        reason = str(row.get("v2_reason") or "unknown")
+        by_reason[reason]["n"] += 1
+        by_reason[reason]["correct"] += int(is_correct)
+        by_reason[reason]["invalid"] += int(is_invalid)
+        by_reason[reason]["hitmax"] += int(is_hitmax)
+
+    def pack(counter: collections.Counter[str]) -> dict[str, Any]:
+        n = counter["n"]
+        return {
+            "n": n,
+            "accuracy": counter["correct"] / n if n else None,
+            "invalid_rate": counter["invalid"] / n if n else None,
+            "hit_max_response_length_rate": counter["hitmax"] / n if n else None,
+        }
+
+    return {
+        "note": "This uses v1 step0 predictions and original v1 answer letters on retained ids. It estimates subset quality only; rephrased/reordered prompts need a fresh static evaluation.",
+        "n": total,
+        "accuracy": correct / total if total else None,
+        "invalid_rate": invalid / total if total else None,
+        "hit_max_response_length_rate": hitmax / total if total else None,
+        "by_question_type": {key: pack(value) for key, value in sorted(by_qtype.items())},
+        "by_v2_reason": {key: pack(value) for key, value in sorted(by_reason.items())},
+    }
+
+
+def build_verl_row(sidecar_row: dict[str, Any], old_verl_by_id: dict[str, dict[str, Any]]) -> dict[str, Any]:
+    old = old_verl_by_id[sidecar_row["id"]]
+    return {
+        "prompt": render_prompt(str(sidecar_row.get("question") or ""), sidecar_row["choices"]),
+        "image_path": old.get("image_path"),
+        "answer": LETTERS[int(sidecar_row["answer_index"])],
+        "source": "physxnet_mcq_cleaned_options_v2_candidate",
+        "id": sidecar_row["id"],
+    }
+
+
+def make_joint_row(row: dict[str, Any], variant: str, seed: int) -> tuple[dict[str, Any] | None, str | None]:
+    source = row.get("source") or {}
+    raw_label = str(source.get("kinematic_type_raw") or "")
+    if variant in {"pragmatic_plain_balanced", "joint_plain_no_static"} and raw_label == "A":
+        return None, "drop_static_no_movement_joint"
+    if variant in {"diagnostic_motion_reliable", "joint_motion_reliable"} and raw_label not in {"C", "D", "CB"}:
+        return None, "drop_low_reliability_static_or_prismatic_joint"
+    answer = JOINT_RAW_TO_PLAIN.get(raw_label)
+    if answer is None:
+        return None, "unknown_joint_raw_label"
+    choices = stable_shuffle(JOINT_PLAIN_OPTIONS, str(row["id"]), seed)
+    answer_index = choices.index(answer)
+    out = dict(row)
+    src = dict(source)
+    v2 = {
+        "version": "physx_cleaned_options_v2_candidate",
+        "parent_cleaning_version": row.get("cleaning_version"),
+        "v2_variant": variant,
+        "v2_reason": "joint_plain_language_no_static" if raw_label != "A" else "joint_plain_language",
+        "original_v1_answer": row.get("answer"),
+        "original_v1_answer_index": row.get("answer_index"),
+        "original_v1_answer_letter": LETTERS[int(row["answer_index"])],
+        "original_v1_choices": row.get("choices"),
+        "joint_raw_label": raw_label,
+    }
+    src["cleaning_v2"] = v2
+    out.update(
+        {
+            "choices": choices,
+            "answer": answer,
+            "answer_index": answer_index,
+            "source": src,
+            "cleaning_version": "physx_cleaned_options_v2_candidate",
+            "v2_variant": variant,
+            "v2_reason": v2["v2_reason"],
+            "v2_parent_id": row.get("id"),
+        }
+    )
+    return out, None
+
+
+def make_movable_row(row: dict[str, Any], variant: str, seed: int) -> tuple[dict[str, Any] | None, str | None]:
+    answer = str(row.get("answer") or "")
+    choices = [display_part_label(choice) for choice in row.get("choices") or []]
+    if len(choices) != 4:
+        return None, "invalid_movable_choices"
+    normalized = [normalize_text(choice) for choice in choices]
+    if len(set(normalized)) != 4:
+        return None, "duplicate_after_part_label_normalization"
+    if not is_visible_part_label(answer):
+        return None, "drop_low_visibility_answer_label"
+    if is_bad_part_label(answer):
+        return None, "drop_bad_answer_label"
+    if any(is_bad_part_label(choice) for choice in choices):
+        return None, "drop_bad_choice_label"
+    if generic_choice_count(choices) >= 3:
+        return None, "drop_too_many_generic_choice_labels"
+    answer_display = display_part_label(answer)
+    answer_norm = normalize_text(answer_display)
+    if answer_norm not in normalized:
+        return None, "answer_missing_after_normalization"
+    choices = stable_shuffle(choices, str(row["id"]), seed)
+    normalized = [normalize_text(choice) for choice in choices]
+    answer_index = normalized.index(answer_norm)
+    out = dict(row)
+    source = dict(row.get("source") or {})
+    v2 = {
+        "version": "physx_cleaned_options_v2_candidate",
+        "parent_cleaning_version": row.get("cleaning_version"),
+        "v2_variant": variant,
+        "v2_reason": "movable_visible_part_labels",
+        "original_v1_answer": row.get("answer"),
+        "original_v1_answer_index": row.get("answer_index"),
+        "original_v1_answer_letter": LETTERS[int(row["answer_index"])],
+        "original_v1_choices": row.get("choices"),
+    }
+    source["cleaning_v2"] = v2
+    out.update(
+        {
+            "choices": choices,
+            "answer": answer_display,
+            "answer_index": answer_index,
+            "source": source,
+            "cleaning_version": "physx_cleaned_options_v2_candidate",
+            "v2_variant": variant,
+            "v2_reason": v2["v2_reason"],
+            "v2_parent_id": row.get("id"),
+        }
+    )
+    return out, None
+
+
+def make_variant(
+    *,
+    variant: str,
+    sidecar_rows: list[dict[str, Any]],
+    old_verl_by_id: dict[str, dict[str, Any]],
+    predictions: dict[str, dict[str, Any]],
+    output_dir: Path,
+    seed: int,
+) -> dict[str, Any]:
+    kept: list[dict[str, Any]] = []
+    skipped: list[dict[str, Any]] = []
+    for row in sidecar_rows:
+        qtype = str(row.get("question_type") or "")
+        if variant in {"joint_plain_no_static", "joint_motion_reliable"} and qtype != "joint_type":
+            skipped.append({"id": row.get("id"), "question_type": qtype, "reason": "variant_excludes_question_type"})
+            continue
+        if variant == "movable_visible_strict" and qtype != "movable_part":
+            skipped.append({"id": row.get("id"), "question_type": qtype, "reason": "variant_excludes_question_type"})
+            continue
+        if qtype == "joint_type":
+            new_row, reason = make_joint_row(row, variant, seed)
+        elif qtype == "movable_part":
+            new_row, reason = make_movable_row(row, variant, seed)
+        else:
+            new_row, reason = None, "unsupported_question_type"
+        if new_row is None:
+            skipped.append({"id": row.get("id"), "question_type": qtype, "reason": reason or "unknown"})
+        else:
+            kept.append(new_row)
+
+    variant_dir = output_dir / variant
+    sidecar_path = variant_dir / f"physxnet_mcq_{variant}.jsonl"
+    verl_path = variant_dir / f"physxnet_mcq_verl_{variant}.json"
+    skipped_path = variant_dir / "skipped_v2_candidate_cases.jsonl"
+    manifest_path = variant_dir / "manifest.json"
+    report_path = variant_dir / "retained_step0_estimate.md"
+    kept_verl = [build_verl_row(row, old_verl_by_id) for row in kept]
+    estimate = retained_estimate(kept, predictions)
+    skipped_reasons = collections.Counter(str(row["reason"]) for row in skipped)
+    kept_qtypes = collections.Counter(str(row.get("question_type") or "unknown") for row in kept)
+    manifest = {
+        "variant": variant,
+        "seed": seed,
+        "num_kept": len(kept),
+        "num_skipped": len(skipped),
+        "kept_by_question_type": dict(sorted(kept_qtypes.items())),
+        "skipped_reasons": dict(sorted(skipped_reasons.items())),
+        "dataset_path": str(verl_path),
+        "sidecar_path": str(sidecar_path),
+        "skipped_path": str(skipped_path),
+        "retained_step0_estimate": estimate,
+    }
+    write_jsonl(sidecar_path, kept)
+    write_json(verl_path, kept_verl)
+    write_jsonl(skipped_path, skipped)
+    write_json(manifest_path, manifest)
+    report_path.write_text(render_report(manifest), encoding="utf-8")
+    return manifest
+
+
+def fmt(value: Any) -> str:
+    if value is None:
+        return "n/a"
+    if isinstance(value, float):
+        return f"{value:.4f}"
+    return str(value)
+
+
+def render_report(manifest: dict[str, Any]) -> str:
+    estimate = manifest["retained_step0_estimate"]
+    lines = [
+        f"# {manifest['variant']} retained step0 estimate",
+        "",
+        estimate["note"],
+        "",
+        f"- kept: {manifest['num_kept']}",
+        f"- skipped: {manifest['num_skipped']}",
+        f"- retained-id acc: {fmt(estimate['accuracy'])}",
+        f"- invalid: {fmt(estimate['invalid_rate'])}",
+        f"- hit_max: {fmt(estimate['hit_max_response_length_rate'])}",
+        "",
+        "## By Question Type",
+        "",
+        "| question_type | n | acc | invalid | hit_max |",
+        "| --- | ---: | ---: | ---: | ---: |",
+    ]
+    for key, row in estimate["by_question_type"].items():
+        lines.append(
+            f"| {key} | {row['n']} | {fmt(row['accuracy'])} | "
+            f"{fmt(row['invalid_rate'])} | {fmt(row['hit_max_response_length_rate'])} |"
+        )
+    lines.extend(["", "## Skipped Reasons", ""])
+    for key, value in manifest["skipped_reasons"].items():
+        lines.append(f"- {key}: {value}")
+    lines.append("")
+    return "\n".join(lines)
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--v1-dataset", type=Path, default=DEFAULT_V1_VERL)
+    parser.add_argument("--v1-sidecar", type=Path, default=DEFAULT_V1_SIDECAR)
+    parser.add_argument("--step0-predictions", type=Path, default=DEFAULT_STEP0)
+    parser.add_argument("--output-dir", type=Path, default=DEFAULT_OUTPUT_DIR)
+    parser.add_argument("--seed", type=int, default=13)
+    args = parser.parse_args()
+
+    v1_verl = read_json(args.v1_dataset)
+    v1_sidecar = read_jsonl(args.v1_sidecar)
+    old_verl_by_id = {str(row["id"]): row for row in v1_verl}
+    predictions = load_prediction_map(args.step0_predictions)
+    args.output_dir.mkdir(parents=True, exist_ok=True)
+
+    variants = [
+        "pragmatic_plain_balanced",
+        "joint_plain_no_static",
+        "joint_motion_reliable",
+        "movable_visible_strict",
+    ]
+    manifests = [
+        make_variant(
+            variant=variant,
+            sidecar_rows=v1_sidecar,
+            old_verl_by_id=old_verl_by_id,
+            predictions=predictions,
+            output_dir=args.output_dir,
+            seed=args.seed,
+        )
+        for variant in variants
+    ]
+    summary = {
+        "source_v1_dataset": str(args.v1_dataset),
+        "source_v1_sidecar": str(args.v1_sidecar),
+        "step0_predictions": str(args.step0_predictions),
+        "output_dir": str(args.output_dir),
+        "variants": manifests,
+    }
+    write_json(args.output_dir / "summary.json", summary)
+    lines = [
+        "# PhysX Cleaned Options V2 Candidate Summary",
+        "",
+        "All variants keep the VERL/sidecar schema and write new files only under this output directory.",
+        "Retained-id metrics are computed with v1 step0 predictions and original v1 answer letters; rephrased/reordered prompts require a fresh static eval.",
+        "",
+        "| variant | kept | joint | movable | retained acc | invalid | hit_max |",
+        "| --- | ---: | ---: | ---: | ---: | ---: | ---: |",
+    ]
+    for manifest in manifests:
+        estimate = manifest["retained_step0_estimate"]
+        q = manifest["kept_by_question_type"]
+        lines.append(
+            f"| {manifest['variant']} | {manifest['num_kept']} | {q.get('joint_type', 0)} | "
+            f"{q.get('movable_part', 0)} | {fmt(estimate['accuracy'])} | "
+            f"{fmt(estimate['invalid_rate'])} | {fmt(estimate['hit_max_response_length_rate'])} |"
+        )
+    lines.append("")
+    (args.output_dir / "summary.md").write_text("\n".join(lines), encoding="utf-8")
+    print(args.output_dir / "summary.md")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
