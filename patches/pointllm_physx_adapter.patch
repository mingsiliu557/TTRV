+#!/usr/bin/env python
+"""Validate the local PhysXNet MCQ files used by PointLLM evaluation."""
+
+from __future__ import annotations
+
+import argparse
+import collections
+import json
+import re
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+
+DEFAULT_DATASET = Path(
+    "/root/autodl-tmp/TTRV/physx_mcq_workspace/PhysX-3D/outputs/physxnet_mcq_verl.json"
+)
+DEFAULT_SIDECAR = Path(
+    "/root/autodl-tmp/TTRV/physx_mcq_workspace/PhysX-3D/outputs/physxnet_mcq.jsonl"
+)
+DEFAULT_OUTPUT = Path("/root/autodl-tmp/TTRV/pointllm-src/outputs/physx_mcq_dataset_validation")
+OPTION_RE = re.compile(r"^\s*([ABCD])\.\s*(.*?)\s*$")
+
+
+def load_dataset(path: Path) -> List[Dict[str, Any]]:
+    with path.open("r", encoding="utf-8") as f:
+        data = json.load(f)
+    if not isinstance(data, list):
+        raise ValueError(f"Expected list in {path}, got {type(data).__name__}")
+    return data
+
+
+def load_sidecar(path: Path) -> Dict[str, Dict[str, Any]]:
+    rows: Dict[str, Dict[str, Any]] = {}
+    with path.open("r", encoding="utf-8") as f:
+        for line in f:
+            if line.strip():
+                row = json.loads(line)
+                rows[row["id"]] = row
+    return rows
+
+
+def parse_prompt_options(prompt: str) -> Dict[str, str]:
+    options: Dict[str, str] = {}
+    for line in prompt.splitlines():
+        match = OPTION_RE.match(line)
+        if match:
+            options[match.group(1)] = match.group(2)
+    return options
+
+
+def normalize_text(text: Any) -> str:
+    return re.sub(r"\s+", " ", str(text or "")).strip().lower()
+
+
+def add_issue(
+    issues: collections.Counter,
+    examples: Dict[str, List[Dict[str, Any]]],
+    key: str,
+    item: Dict[str, Any],
+    detail: str,
+    max_examples: int,
+) -> None:
+    issues[key] += 1
+    bucket = examples.setdefault(key, [])
+    if len(bucket) < max_examples:
+        bucket.append({"id": item.get("id"), "detail": detail})
+
+
+def object_id_from_image_path(image_path: str) -> Optional[str]:
+    marker = "/partseg/"
+    if marker not in image_path:
+        return None
+    return image_path.split(marker, 1)[1].split("/", 1)[0]
+
+
+def validate(args: argparse.Namespace) -> Dict[str, Any]:
+    dataset = load_dataset(args.dataset_path)
+    sidecar = load_sidecar(args.sidecar_path)
+    issues: collections.Counter[str] = collections.Counter()
+    issue_examples: Dict[str, List[Dict[str, Any]]] = {}
+    question_types: collections.Counter[str] = collections.Counter()
+    ids_seen = set()
+
+    for index, item in enumerate(dataset):
+        item_id = item.get("id")
+        if not item_id:
+            add_issue(issues, issue_examples, "missing_id", item, f"dataset_index={index}", args.max_issue_examples)
+            continue
+        if item_id in ids_seen:
+            add_issue(issues, issue_examples, "duplicate_id", item, f"dataset_index={index}", args.max_issue_examples)
+        ids_seen.add(item_id)
+
+        prompt = item.get("prompt")
+        if not isinstance(prompt, str) or not prompt.strip():
+            add_issue(issues, issue_examples, "missing_prompt", item, f"dataset_index={index}", args.max_issue_examples)
+            continue
+
+        if prompt.count("<image>") != 1:
+            add_issue(
+                issues,
+                issue_examples,
+                "image_placeholder_count_not_one",
+                item,
+                f"count={prompt.count('<image>')}",
+                args.max_issue_examples,
+            )
+        for phrase, key in [
+            ("Choose the correct answer from the options below", "missing_choose_instruction"),
+            ("respond with only the corresponding option letter", "missing_letter_only_instruction"),
+            ("Do not include any explanation or extra text", "missing_no_explanation_instruction"),
+            ("Options:", "missing_options_header"),
+        ]:
+            if phrase not in prompt:
+                add_issue(issues, issue_examples, key, item, phrase, args.max_issue_examples)
+
+        options = parse_prompt_options(prompt)
+        if set(options) != {"A", "B", "C", "D"}:
+            add_issue(
+                issues,
+                issue_examples,
+                "malformed_prompt_options",
+                item,
+                f"letters={sorted(options)}",
+                args.max_issue_examples,
+            )
+        if len({normalize_text(v) for v in options.values()}) != len(options):
+            add_issue(issues, issue_examples, "duplicate_prompt_option_text", item, str(options), args.max_issue_examples)
+
+        answer = str(item.get("answer", "")).strip().upper()
+        if answer not in {"A", "B", "C", "D"}:
+            add_issue(issues, issue_examples, "invalid_answer_letter", item, repr(item.get("answer")), args.max_issue_examples)
+        elif answer not in options:
+            add_issue(
+                issues,
+                issue_examples,
+                "answer_letter_missing_from_prompt_options",
+                item,
+                f"answer={answer}, options={sorted(options)}",
+                args.max_issue_examples,
+            )
+
+        image_path = Path(str(item.get("image_path", "")))
+        if not image_path.exists():
+            add_issue(issues, issue_examples, "missing_image_path", item, str(image_path), args.max_issue_examples)
+        object_id_from_path = object_id_from_image_path(str(image_path))
+        if object_id_from_path:
+            obj_dir = image_path.parents[1] / "objs"
+            if not obj_dir.exists() or not any(obj_dir.glob("*.obj")):
+                add_issue(issues, issue_examples, "missing_object_obj_files", item, str(obj_dir), args.max_issue_examples)
+        else:
+            add_issue(issues, issue_examples, "cannot_parse_object_id_from_image_path", item, str(image_path), args.max_issue_examples)
+
+        meta = sidecar.get(item_id)
+        if meta is None:
+            add_issue(issues, issue_examples, "missing_sidecar_row", item, item_id, args.max_issue_examples)
+            continue
+
+        question_type = meta.get("question_type", "unknown")
+        question_types[question_type] += 1
+        if str(meta.get("object_id")) != str(object_id_from_path):
+            add_issue(
+                issues,
+                issue_examples,
+                "object_id_mismatch_sidecar_image_path",
+                item,
+                f"sidecar={meta.get('object_id')} image_path={object_id_from_path}",
+                args.max_issue_examples,
+            )
+
+        answer_index = meta.get("answer_index")
+        if not isinstance(answer_index, int) or not 0 <= answer_index <= 3:
+            add_issue(issues, issue_examples, "invalid_sidecar_answer_index", item, repr(answer_index), args.max_issue_examples)
+        else:
+            expected_letter = "ABCD"[answer_index]
+            if answer != expected_letter:
+                add_issue(
+                    issues,
+                    issue_examples,
+                    "answer_letter_sidecar_index_mismatch",
+                    item,
+                    f"dataset={answer} sidecar={expected_letter}",
+                    args.max_issue_examples,
+                )
+
+        choices = meta.get("choices")
+        if not isinstance(choices, list) or len(choices) != 4:
+            add_issue(issues, issue_examples, "invalid_sidecar_choices", item, repr(choices), args.max_issue_examples)
+        elif set(options) == {"A", "B", "C", "D"}:
+            for letter, choice in zip("ABCD", choices):
+                if normalize_text(options[letter]) != normalize_text(choice):
+                    add_issue(
+                        issues,
+                        issue_examples,
+                        "prompt_sidecar_choice_mismatch",
+                        item,
+                        f"{letter}: prompt={options[letter]!r} sidecar={choice!r}",
+                        args.max_issue_examples,
+                    )
+                    break
+            if isinstance(answer_index, int) and 0 <= answer_index <= 3:
+                answer_text = meta.get("answer")
+                if normalize_text(answer_text) != normalize_text(choices[answer_index]):
+                    add_issue(
+                        issues,
+                        issue_examples,
+                        "sidecar_answer_text_mismatch",
+                        item,
+                        f"answer={answer_text!r} choice={choices[answer_index]!r}",
+                        args.max_issue_examples,
+                    )
+
+    missing_from_dataset = sorted(set(sidecar) - ids_seen)
+    if missing_from_dataset:
+        issues["sidecar_rows_not_in_dataset"] = len(missing_from_dataset)
+        issue_examples["sidecar_rows_not_in_dataset"] = [
+            {"id": item_id, "detail": "sidecar id absent from verl JSON"} for item_id in missing_from_dataset[: args.max_issue_examples]
+        ]
+
+    hard_issue_keys = {
+        key
+        for key in issues
+        if key
+        not in {
+            "missing_no_explanation_instruction",
+            "missing_letter_only_instruction",
+            "missing_choose_instruction",
+        }
+    }
+    return {
+        "dataset_path": str(args.dataset_path),
+        "sidecar_path": str(args.sidecar_path),
+        "num_dataset": len(dataset),
+        "num_sidecar": len(sidecar),
+        "question_type_counts": dict(question_types),
+        "issues": dict(issues),
+        "issue_examples": issue_examples,
+        "requires_dataset_fix": bool(hard_issue_keys),
+        "verl_prompt_compatibility": {
+            "has_image_placeholder": issues.get("image_placeholder_count_not_one", 0) == 0,
+            "has_options_header": issues.get("missing_options_header", 0) == 0,
+            "has_abcd_options": issues.get("malformed_prompt_options", 0) == 0,
+            "has_letter_only_instruction": issues.get("missing_letter_only_instruction", 0) == 0,
+            "has_no_explanation_instruction": issues.get("missing_no_explanation_instruction", 0) == 0,
+        },
+    }
+
+
+def render_markdown(report: Dict[str, Any]) -> str:
+    lines = [
+        "# PhysX MCQ Dataset Validation",
+        "",
+        f"- Dataset path: `{report['dataset_path']}`",
+        f"- Sidecar path: `{report['sidecar_path']}`",
+        f"- Dataset rows: {report['num_dataset']}",
+        f"- Sidecar rows: {report['num_sidecar']}",
+        f"- Requires dataset fix: {report['requires_dataset_fix']}",
+        "",
+        "## Question Types",
+        "",
+    ]
+    for key, value in sorted(report["question_type_counts"].items()):
+        lines.append(f"- {key}: {value}")
+    lines.extend(["", "## Issues", ""])
+    if report["issues"]:
+        for key, value in sorted(report["issues"].items()):
+            lines.append(f"- {key}: {value}")
+    else:
+        lines.append("- none")
+    lines.extend(["", "## VERL Prompt Compatibility", ""])
+    for key, value in report["verl_prompt_compatibility"].items():
+        lines.append(f"- {key}: {value}")
+    lines.extend(["", "## Issue Examples", ""])
+    if report["issue_examples"]:
+        for key, examples in sorted(report["issue_examples"].items()):
+            lines.append(f"### {key}")
+            for example in examples:
+                lines.append(f"- {example['id']}: {example['detail']}")
+    else:
+        lines.append("- none")
+    lines.append("")
+    return "\n".join(lines)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--dataset_path", type=Path, default=DEFAULT_DATASET)
+    parser.add_argument("--sidecar_path", type=Path, default=DEFAULT_SIDECAR)
+    parser.add_argument("--output_prefix", type=Path, default=DEFAULT_OUTPUT)
+    parser.add_argument("--max_issue_examples", type=int, default=20)
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    report = validate(args)
+    args.output_prefix.parent.mkdir(parents=True, exist_ok=True)
+    json_path = args.output_prefix.with_suffix(".json")
+    md_path = args.output_prefix.with_suffix(".md")
+    json_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+    md_path.write_text(render_markdown(report), encoding="utf-8")
+    print(json.dumps(report, ensure_ascii=False, indent=2))
+    print(f"Wrote {json_path}")
+    print(f"Wrote {md_path}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
