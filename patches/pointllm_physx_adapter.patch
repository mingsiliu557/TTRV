+#!/usr/bin/env python3
+"""Build cleaned PhysX-MCQ option sets and bad-case audit reports.
+
+The script reads the original PhysX-MCQ VERL JSON and JSONL sidecar, writes a
+separate cleaned dataset, and never modifies the original PhysXNet files.
+"""
+
+from __future__ import annotations
+
+import argparse
+import collections
+import json
+import math
+import re
+import sys
+from pathlib import Path
+from typing import Any, Iterable
+
+SCRIPT_DIR = Path(__file__).resolve().parent
+REPO_ROOT = SCRIPT_DIR.parents[0]
+TTRV_ROOT = REPO_ROOT.parent
+PHYSX_ROOT = TTRV_ROOT / "physx_mcq_workspace" / "PhysX-3D"
+
+DEFAULT_DATASET = PHYSX_ROOT / "outputs" / "physxnet_mcq_verl.json"
+DEFAULT_SIDECAR = PHYSX_ROOT / "outputs" / "physxnet_mcq.jsonl"
+DEFAULT_OUTPUT_DIR = TTRV_ROOT / "outputs" / "physx_cleaned_options_v1"
+DEFAULT_FIXED_STEP0 = TTRV_ROOT / "results" / "physx_geo_harmony_qtype_repro_20260526" / "fixed_step0_caches"
+DEFAULT_JOINT_VOTE8 = (
+    TTRV_ROOT
+    / "outputs"
+    / "20260526_geo_harmony_full_joint_type_vote8_sensor_baseline_keep"
+    / "validation_predictions_step0.jsonl"
+)
+DEFAULT_MOVABLE_VOTE8 = (
+    TTRV_ROOT
+    / "outputs"
+    / "20260526_geo_harmony_full_movable_part_vote8_sensor_baseline_keep"
+    / "validation_predictions_step0.jsonl"
+)
+
+if str(PHYSX_ROOT) not in sys.path:
+    sys.path.insert(0, str(PHYSX_ROOT))
+
+from qa_builder.parser import parse_annotation  # noqa: E402
+from qa_builder.utils import normalize_choice  # noqa: E402
+
+LETTERS = "ABCD"
+JOINT_CANONICAL_OPTIONS = [
+    "fixed or rigid joint (no movement)",
+    "prismatic joint",
+    "revolute or hinge joint",
+    "compound prismatic and revolute joint",
+]
+JOINT_RAW_TO_CANONICAL = {
+    "A": "fixed or rigid joint (no movement)",
+    "E": "fixed or rigid joint (no movement)",
+    "B": "prismatic joint",
+    "C": "revolute or hinge joint",
+    "D": "revolute or hinge joint",
+    "CB": "compound prismatic and revolute joint",
+}
+JOINT_CONFLICT_GROUPS = {
+    "hinge_vs_revolute": ("hinge", "revolute"),
+    "slider_vs_prismatic": ("slider", "prismatic"),
+    "fixed_vs_rigid": ("fixed", "rigid"),
+}
+
+
+def read_json(path: Path) -> Any:
+    with path.open("r", encoding="utf-8") as handle:
+        return json.load(handle)
+
+
+def read_jsonl(path: Path) -> list[dict[str, Any]]:
+    rows: list[dict[str, Any]] = []
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line.strip():
+                rows.append(json.loads(line))
+    return rows
+
+
+def write_json(path: Path, payload: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+
+def normalize_text(value: Any) -> str:
+    return re.sub(r"[^a-z0-9]+", " ", str(value or "").lower()).strip()
+
+
+def option_map(choices: list[str]) -> dict[str, str]:
+    return {letter: choice for letter, choice in zip(LETTERS, choices)}
+
+
+def parse_prompt_options(prompt: Any) -> dict[str, str]:
+    matches = re.findall(
+        r"(?:^|\n)\s*([ABCD])\.\s*(.*?)(?=(?:\n\s*[ABCD]\.)|$)",
+        str(prompt or ""),
+        flags=re.S,
+    )
+    return {letter: text.strip() for letter, text in matches}
+
+
+def render_prompt(question: str, choices: list[str]) -> str:
+    lines = [
+        "<image> ",
+        (
+            f"{question} Choose the correct answer from the options below and respond with only the "
+            "corresponding option letter (A, B, C, or D). Do not include any explanation or extra text. "
+        ),
+        "Options:",
+    ]
+    lines.extend(f"{letter}. {choice}" for letter, choice in zip(LETTERS, choices))
+    return "\n".join(lines)
+
+
+def source_json_path(source: dict[str, Any]) -> Path:
+    raw = Path(str(source.get("json_file") or ""))
+    if raw.is_absolute():
+        return raw
+    return PHYSX_ROOT / raw
+
+
+def annotation_part_names(source: dict[str, Any], cache: dict[str, list[str]]) -> list[str]:
+    path = source_json_path(source)
+    key = str(path)
+    if key not in cache:
+        annotation = parse_annotation(path)
+        cache[key] = annotation.part_names
+    return cache[key]
+
+
+def ordered_choices_with_answer(answer_text: str, all_choices: list[str], answer_index: int) -> tuple[list[str], int]:
+    if answer_text not in all_choices:
+        raise ValueError(f"answer_text not in all_choices: {answer_text!r}")
+    if not 0 <= int(answer_index) <= 3:
+        raise ValueError(f"invalid answer_index: {answer_index!r}")
+    answer_index = int(answer_index)
+    distractors = [choice for choice in all_choices if normalize_choice(choice) != normalize_choice(answer_text)]
+    if len(distractors) != 3:
+        raise ValueError(f"expected exactly 3 distractors for {answer_text!r}, got {distractors!r}")
+    choices: list[str] = []
+    it = iter(distractors)
+    for idx in range(4):
+        choices.append(answer_text if idx == answer_index else next(it))
+    return choices, answer_index
+
+
+def joint_conflict_reasons(choices: list[str]) -> list[str]:
+    opts = option_map(choices)
+    reasons: list[str] = []
+    normalized = {letter: f" {normalize_text(text)} " for letter, text in opts.items()}
+    for name, terms in JOINT_CONFLICT_GROUPS.items():
+        term_letters: dict[str, set[str]] = collections.defaultdict(set)
+        for letter, text in normalized.items():
+            for term in terms:
+                if f" {term} " in text:
+                    term_letters[term].add(letter)
+        matched_terms = [term for term, letters in term_letters.items() if letters]
+        matched_letters = set().union(*(term_letters[term] for term in matched_terms)) if matched_terms else set()
+        if len(matched_terms) >= 2 and len(matched_letters) >= 2:
+            reasons.append(name)
+
+    texts = [normalize_text(choice) for choice in choices]
+    has_compound = any("prismatic and revolute" in text for text in texts)
+    has_single = any(text == "prismatic joint" or text == "revolute joint" for text in texts)
+    if has_compound and has_single:
+        reasons.append("compound_prismatic_revolute_vs_single")
+    has_rigid = any("rigid joint" in text for text in texts)
+    has_no_constraint = any("no movement" in text or "no constraint" in text for text in texts)
+    if has_rigid and has_no_constraint:
+        reasons.append("rigid_vs_no_constraint")
+    return reasons
+
+
+def build_cleaned_sidecar_row(
+    original: dict[str, Any],
+    *,
+    choices: list[str],
+    answer_index: int,
+    cleaning_reason: str,
+    cleaning_notes: dict[str, Any],
+) -> dict[str, Any]:
+    answer = choices[answer_index]
+    source = dict(original.get("source") or {})
+    clean_meta = {
+        "version": "physx_cleaned_options_v1",
+        "original_id": original.get("id"),
+        "original_answer": original.get("answer"),
+        "original_answer_index": original.get("answer_index"),
+        "original_choices": original.get("choices"),
+        "cleaning_reason": cleaning_reason,
+        **cleaning_notes,
+    }
+    source["cleaning"] = clean_meta
+    row = dict(original)
+    row.update(
+        {
+            "choices": choices,
+            "answer": answer,
+            "answer_index": answer_index,
+            "source": source,
+            "cleaning_version": "physx_cleaned_options_v1",
+            "original_id": original.get("id"),
+            "original_answer": original.get("answer"),
+            "original_answer_index": original.get("answer_index"),
+            "original_choices": original.get("choices"),
+            "cleaning_reason": cleaning_reason,
+        }
+    )
+    return row
+
+
+def build_verl_row(sidecar_row: dict[str, Any], original_verl_row: dict[str, Any]) -> dict[str, Any]:
+    answer_letter = LETTERS[int(sidecar_row["answer_index"])]
+    return {
+        "prompt": render_prompt(str(sidecar_row.get("question") or ""), sidecar_row["choices"]),
+        "image_path": original_verl_row.get("image_path"),
+        "answer": answer_letter,
+        "source": "physxnet_mcq_cleaned_options_v1",
+        "id": sidecar_row["id"],
+    }
+
+
+def clean_joint(row: dict[str, Any]) -> tuple[dict[str, Any] | None, str | None]:
+    source = row.get("source") or {}
+    raw_label = str(source.get("kinematic_type_raw") or "")
+    answer_text = JOINT_RAW_TO_CANONICAL.get(raw_label)
+    if answer_text is None:
+        return None, "joint_type_unknown_raw_label"
+    choices, answer_index = ordered_choices_with_answer(
+        answer_text=answer_text,
+        all_choices=JOINT_CANONICAL_OPTIONS,
+        answer_index=int(row["answer_index"]),
+    )
+    reasons = joint_conflict_reasons(row.get("choices") or [])
+    return (
+        build_cleaned_sidecar_row(
+            row,
+            choices=choices,
+            answer_index=answer_index,
+            cleaning_reason="joint_type_canonical_mutually_exclusive",
+            cleaning_notes={
+                "joint_raw_label": raw_label,
+                "joint_canonical_label": answer_text,
+                "original_conflict_reasons": reasons,
+            },
+        ),
+        None,
+    )
+
+
+def clean_movable(row: dict[str, Any], part_cache: dict[str, list[str]]) -> tuple[dict[str, Any] | None, str | None]:
+    answer = str(row.get("answer") or "").strip()
+    source = row.get("source") or {}
+    part_names = annotation_part_names(source, part_cache)
+    answer_key = normalize_choice(answer)
+    distractors: list[str] = []
+    seen = {answer_key}
+    for name in part_names:
+        key = normalize_choice(name)
+        if not key or key in seen:
+            continue
+        seen.add(key)
+        distractors.append(name)
+    if len(distractors) < 3:
+        return None, "movable_part_not_enough_same_object_distractors"
+    answer_index = int(row["answer_index"])
+    choices: list[str] = []
+    distractor_iter = iter(distractors[:3])
+    for idx in range(4):
+        choices.append(answer if idx == answer_index else next(distractor_iter))
+    return (
+        build_cleaned_sidecar_row(
+            row,
+            choices=choices,
+            answer_index=answer_index,
+            cleaning_reason="movable_part_same_object_distractors",
+            cleaning_notes={
+                "same_object_part_count": len(part_names),
+                "same_object_distractor_count": len(distractors),
+            },
+        ),
+        None,
+    )
+
+
+def safe_prediction(record: dict[str, Any]) -> str:
+    return str(record.get("prediction") or record.get("pred") or "unknown")
+
+
+def safe_answer(record: dict[str, Any]) -> str:
+    return str(record.get("answer") or record.get("ground_truth") or "")
+
+
+def load_prediction_groups(path: Path | None) -> dict[str, list[dict[str, Any]]]:
+    if path is None or not path.exists():
+        return {}
+    groups: dict[str, list[dict[str, Any]]] = collections.defaultdict(list)
+    for row in read_jsonl(path):
+        key = str(row.get("index") or row.get("id") or "")
+        if key:
+            groups[key].append(row)
+    return dict(groups)
+
+
+def accuracy_for_ids(predictions: dict[str, list[dict[str, Any]]], ids: set[str]) -> dict[str, Any]:
+    rows = [group[0] for key, group in predictions.items() if key in ids and group]
+    n = len(rows)
+    correct = sum(1 for row in rows if safe_prediction(row) == safe_answer(row))
+    invalid = sum(1 for row in rows if safe_prediction(row) == "unknown")
+    hitmax = sum(1 for row in rows if bool(row.get("hit_max_response_length")))
+    confusion: collections.Counter[tuple[str, str]] = collections.Counter(
+        (safe_answer(row), safe_prediction(row)) for row in rows
+    )
+    return {
+        "num_records": n,
+        "accuracy": correct / n if n else None,
+        "invalid_rate": invalid / n if n else None,
+        "hit_max_response_length_rate": hitmax / n if n else None,
+        "confusion": {f"{answer}->{pred}": count for (answer, pred), count in sorted(confusion.items())},
+    }
+
+
+def vote8_for_ids(groups: dict[str, list[dict[str, Any]]], ids: set[str]) -> dict[str, Any]:
+    selected = {key: group for key, group in groups.items() if key in ids}
+    n = len(selected)
+    majority_correct = 0
+    high_conf_wrong = 0
+    high_conf_all = 0
+    pass_at_votes = 0
+    majority_counts: collections.Counter[int] = collections.Counter()
+    for group in selected.values():
+        preds = [safe_prediction(row) for row in group]
+        counts = collections.Counter(preds)
+        majority_pred, majority_count = counts.most_common(1)[0]
+        answer = safe_answer(group[0])
+        majority_counts[majority_count] += 1
+        majority_correct += int(majority_pred == answer)
+        high_conf = majority_count / len(group) >= 0.75 if group else False
+        high_conf_all += int(high_conf)
+        high_conf_wrong += int(high_conf and majority_pred != answer)
+        pass_at_votes += int(any(pred == answer for pred in preds))
+    return {
+        "num_groups": n,
+        "majority_accuracy": majority_correct / n if n else None,
+        "high_confidence_wrong_count": high_conf_wrong,
+        "high_confidence_all_count": high_conf_all,
+        "pass_at_votes": pass_at_votes / n if n else None,
+        "majority_count_distribution": dict(sorted(majority_counts.items())),
+    }
+
+
+def pct(value: float | None) -> str:
+    return "n/a" if value is None else f"{value:.6f}"
+
+
+def render_audit_markdown(summary: dict[str, Any]) -> str:
+    lines = [
+        "# PhysX Cleaned Options V1 Audit",
+        "",
+        "## Dataset",
+        "",
+        f"- Original rows: {summary['original_counts']['total']}",
+        f"- Cleaned rows: {summary['cleaned_counts']['total']}",
+        f"- Output dir: `{summary['output_dir']}`",
+        "",
+        "## Question Types",
+        "",
+        "| question_type | original | cleaned | skipped |",
+        "| --- | ---: | ---: | ---: |",
+    ]
+    qtypes = sorted(set(summary["original_counts"]["by_question_type"]) | set(summary["cleaned_counts"]["by_question_type"]))
+    for qtype in qtypes:
+        original = summary["original_counts"]["by_question_type"].get(qtype, 0)
+        cleaned = summary["cleaned_counts"]["by_question_type"].get(qtype, 0)
+        skipped = summary["skipped_by_question_type"].get(qtype, 0)
+        lines.append(f"| {qtype} | {original} | {cleaned} | {skipped} |")
+
+    lines.extend(["", "## Skipped Reasons", ""])
+    if summary["skipped_reasons"]:
+        for reason, count in sorted(summary["skipped_reasons"].items()):
+            lines.append(f"- {reason}: {count}")
+    else:
+        lines.append("- none")
+
+    lines.extend(["", "## Original Fixed Step0 On Retained IDs", ""])
+    lines.append("| question_type | n | acc | invalid | hitmax |")
+    lines.append("| --- | ---: | ---: | ---: | ---: |")
+    for qtype, row in sorted(summary["original_fixed_step0_retained"].items()):
+        lines.append(
+            f"| {qtype} | {row['num_records']} | {pct(row['accuracy'])} | "
+            f"{pct(row['invalid_rate'])} | {pct(row['hit_max_response_length_rate'])} |"
+        )
+
+    lines.extend(["", "## Original Vote8 On Retained IDs", ""])
+    lines.append("| question_type | groups | majority_acc | pass@8 | high_conf_wrong | high_conf_all |")
+    lines.append("| --- | ---: | ---: | ---: | ---: | ---: |")
+    for qtype, row in sorted(summary["original_vote8_retained"].items()):
+        lines.append(
+            f"| {qtype} | {row['num_groups']} | {pct(row['majority_accuracy'])} | "
+            f"{pct(row['pass_at_votes'])} | {row['high_confidence_wrong_count']} | "
+            f"{row['high_confidence_all_count']} |"
+        )
+
+    lines.extend(["", "## Cleaning Reasons", ""])
+    for reason, count in sorted(summary["cleaning_reasons"].items()):
+        lines.append(f"- {reason}: {count}")
+    lines.append("")
+    return "\n".join(lines)
+
+
+def validate_cleaned(cleaned_verl: list[dict[str, Any]], cleaned_sidecar: list[dict[str, Any]]) -> dict[str, Any]:
+    issues: collections.Counter[str] = collections.Counter()
+    sidecar_by_id = {row.get("id"): row for row in cleaned_sidecar}
+    seen: set[str] = set()
+    for item in cleaned_verl:
+        item_id = item.get("id")
+        if not item_id:
+            issues["missing_id"] += 1
+            continue
+        if item_id in seen:
+            issues["duplicate_id"] += 1
+        seen.add(str(item_id))
+        side = sidecar_by_id.get(item_id)
+        if side is None:
+            issues["missing_sidecar"] += 1
+            continue
+        prompt_options = parse_prompt_options(item.get("prompt"))
+        if set(prompt_options) != set(LETTERS):
+            issues["malformed_prompt_options"] += 1
+        choices = side.get("choices")
+        if not isinstance(choices, list) or len(choices) != 4:
+            issues["invalid_sidecar_choices"] += 1
+            continue
+        if len({normalize_choice(choice) for choice in choices}) != 4:
+            issues["duplicate_choices"] += 1
+        answer_index = side.get("answer_index")
+        if not isinstance(answer_index, int) or not 0 <= answer_index <= 3:
+            issues["invalid_answer_index"] += 1
+            continue
+        if item.get("answer") != LETTERS[answer_index]:
+            issues["answer_letter_mismatch"] += 1
+        if normalize_choice(side.get("answer")) != normalize_choice(choices[answer_index]):
+            issues["answer_text_mismatch"] += 1
+        for letter, choice in zip(LETTERS, choices):
+            if normalize_choice(prompt_options.get(letter)) != normalize_choice(choice):
+                issues["prompt_sidecar_choice_mismatch"] += 1
+                break
+        source = side.get("source") or {}
+        cleaning = source.get("cleaning") or {}
+        if not cleaning.get("original_id"):
+            issues["missing_original_id"] += 1
+    if set(sidecar_by_id) - seen:
+        issues["sidecar_rows_not_in_dataset"] += len(set(sidecar_by_id) - seen)
+    return {"issues": dict(issues), "ok": not issues}
+
+
+def build(args: argparse.Namespace) -> dict[str, Any]:
+    dataset = read_json(args.dataset_path)
+    sidecar_rows = read_jsonl(args.sidecar_path)
+    verl_by_id = {row["id"]: row for row in dataset}
+    part_cache: dict[str, list[str]] = {}
+
+    cleaned_sidecar: list[dict[str, Any]] = []
+    cleaned_verl: list[dict[str, Any]] = []
+    skipped: list[dict[str, Any]] = []
+    original_counts: collections.Counter[str] = collections.Counter()
+    cleaned_counts: collections.Counter[str] = collections.Counter()
+    skipped_qtypes: collections.Counter[str] = collections.Counter()
+    skipped_reasons: collections.Counter[str] = collections.Counter()
+    cleaning_reasons: collections.Counter[str] = collections.Counter()
+    joint_conflicts: collections.Counter[str] = collections.Counter()
+
+    for row in sidecar_rows:
+        qtype = str(row.get("question_type") or "unknown")
+        original_counts[qtype] += 1
+        if qtype == "joint_type":
+            for reason in joint_conflict_reasons(row.get("choices") or []):
+                joint_conflicts[reason] += 1
+            cleaned, reason = clean_joint(row)
+        elif qtype == "movable_part":
+            cleaned, reason = clean_movable(row, part_cache)
+        else:
+            cleaned, reason = None, "object_category_not_in_cleaned_v1"
+
+        if cleaned is None:
+            skipped_reasons[reason or "unknown"] += 1
+            skipped_qtypes[qtype] += 1
+            skipped.append(
+                {
+                    "id": row.get("id"),
+                    "question_type": qtype,
+                    "reason": reason or "unknown",
+                    "object_id": row.get("object_id"),
+                    "answer": row.get("answer"),
+                    "choices": row.get("choices"),
+                }
+            )
+            continue
+
+        original_verl = verl_by_id.get(row["id"])
+        if original_verl is None:
+            skipped_reasons["missing_verl_row"] += 1
+            skipped_qtypes[qtype] += 1
+            skipped.append({"id": row.get("id"), "question_type": qtype, "reason": "missing_verl_row"})
+            continue
+
+        cleaned_sidecar.append(cleaned)
+        cleaned_verl.append(build_verl_row(cleaned, original_verl))
+        cleaned_counts[qtype] += 1
+        cleaning_reasons[str(cleaned.get("cleaning_reason"))] += 1
+
+    out_dir = args.output_dir
+    out_dir.mkdir(parents=True, exist_ok=True)
+    dataset_path = out_dir / "physxnet_mcq_verl_cleaned_options.json"
+    sidecar_path = out_dir / "physxnet_mcq_cleaned_options.jsonl"
+    skipped_path = out_dir / "skipped_cleaning_cases.jsonl"
+    dataset_path.write_text(json.dumps(cleaned_verl, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+    with sidecar_path.open("w", encoding="utf-8") as handle:
+        for row in cleaned_sidecar:
+            handle.write(json.dumps(row, ensure_ascii=False) + "\n")
+    with skipped_path.open("w", encoding="utf-8") as handle:
+        for row in skipped:
+            handle.write(json.dumps(row, ensure_ascii=False) + "\n")
+
+    retained_ids_by_qtype: dict[str, set[str]] = collections.defaultdict(set)
+    for row in cleaned_sidecar:
+        retained_ids_by_qtype[str(row.get("question_type") or "unknown")].add(str(row.get("id")))
+
+    fixed_predictions = {
+        "joint_type": load_prediction_groups(args.fixed_step0_dir / "joint_type_validation_predictions_step0.jsonl"),
+        "movable_part": load_prediction_groups(args.fixed_step0_dir / "movable_part_validation_predictions_step0.jsonl"),
+    }
+    vote_predictions = {
+        "joint_type": load_prediction_groups(args.joint_vote8_path),
+        "movable_part": load_prediction_groups(args.movable_vote8_path),
+    }
+    fixed_retained = {
+        qtype: accuracy_for_ids(groups, retained_ids_by_qtype.get(qtype, set()))
+        for qtype, groups in fixed_predictions.items()
+    }
+    vote_retained = {
+        qtype: vote8_for_ids(groups, retained_ids_by_qtype.get(qtype, set()))
+        for qtype, groups in vote_predictions.items()
+    }
+
+    validation = validate_cleaned(cleaned_verl, cleaned_sidecar)
+    summary = {
+        "version": "physx_cleaned_options_v1",
+        "output_dir": str(out_dir),
+        "dataset_path": str(dataset_path),
+        "sidecar_path": str(sidecar_path),
+        "skipped_path": str(skipped_path),
+        "original_dataset_path": str(args.dataset_path),
+        "original_sidecar_path": str(args.sidecar_path),
+        "original_counts": {
+            "total": len(sidecar_rows),
+            "by_question_type": dict(sorted(original_counts.items())),
+        },
+        "cleaned_counts": {
+            "total": len(cleaned_sidecar),
+            "by_question_type": dict(sorted(cleaned_counts.items())),
+        },
+        "skipped_by_question_type": dict(sorted(skipped_qtypes.items())),
+        "skipped_reasons": dict(sorted(skipped_reasons.items())),
+        "cleaning_reasons": dict(sorted(cleaning_reasons.items())),
+        "joint_original_conflict_reasons": dict(sorted(joint_conflicts.items())),
+        "validation": validation,
+        "original_fixed_step0_retained": fixed_retained,
+        "original_vote8_retained": vote_retained,
+    }
+    write_json(out_dir / "cleaning_manifest.json", summary)
+    (out_dir / "badcase_summary.md").write_text(render_audit_markdown(summary), encoding="utf-8")
+    write_json(out_dir / "badcase_summary.json", summary)
+    return summary
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--dataset-path", type=Path, default=DEFAULT_DATASET)
+    parser.add_argument("--sidecar-path", type=Path, default=DEFAULT_SIDECAR)
+    parser.add_argument("--output-dir", type=Path, default=DEFAULT_OUTPUT_DIR)
+    parser.add_argument("--fixed-step0-dir", type=Path, default=DEFAULT_FIXED_STEP0)
+    parser.add_argument("--joint-vote8-path", type=Path, default=DEFAULT_JOINT_VOTE8)
+    parser.add_argument("--movable-vote8-path", type=Path, default=DEFAULT_MOVABLE_VOTE8)
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    summary = build(args)
+    print(json.dumps(summary, ensure_ascii=False, indent=2))
+    if not summary["validation"]["ok"]:
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
